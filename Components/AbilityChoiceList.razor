@if (Requirements.Count > 0)
{
    <div class="ability-choice-list">
        @foreach (var requirement in Requirements)
        {
            var selected = SelectedChoices.TryGetValue(requirement.Key, out var values) ? values : [];
            <div class="ability-choice-group">
                <div>
                    <strong>@requirement.SourceName</strong>
                    <small>@BuildHint(requirement)</small>
                </div>
                <div class="ability-choice-selects">
                    @for (var index = 0; index < requirement.Count; index++)
                    {
                        var selectedValue = index < selected.Count ? selected[index] : "";
                        <select value="@selectedValue" @onchange="args => SetChoice(requirement, index, args.Value?.ToString())">
                            <option value="">Select ability</option>
                            @foreach (var ability in requirement.Options)
                            {
                                <option value="@ability">@CharacterAbilityChoiceService.FormatAbilityName(ability)</option>
                            }
                        </select>
                    }
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter] public IReadOnlyList<CharacterAbilityChoiceRequirement> Requirements { get; set; } = [];
    [Parameter] public IReadOnlyDictionary<string, List<string>> SelectedChoices { get; set; } = new Dictionary<string, List<string>>(StringComparer.OrdinalIgnoreCase);
    [Parameter] public EventCallback<(string Key, int Index, string Value)> OnChange { get; set; }

    private async Task SetChoice(CharacterAbilityChoiceRequirement requirement, int index, string? value)
    {
        await OnChange.InvokeAsync((requirement.Key, index, value ?? ""));
    }

    private static string BuildHint(CharacterAbilityChoiceRequirement requirement)
    {
        var bonusText = requirement.BonusPerSelection == 1 ? "+1" : $"+{requirement.BonusPerSelection}";
        return requirement.Count == 1
            ? $"Choose one ability ({bonusText})."
            : $"Choose {requirement.Count} ability increases ({bonusText} each).";
    }
}
