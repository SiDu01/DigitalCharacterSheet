@if (Item is not null)
{
    <section class="spell-detail-content item-detail-content">
        <header class="detail-header">
            <div>
                <div class="source-switcher" aria-label="Item source versions">
                    @foreach (var version in ActiveSourceVersions)
                    {
                        <button class="source-version @(version.Id == Item.Id ? "active" : "")"
                                title="@BuildSourceTitle(version)"
                                @onclick="() => SelectVersion(version)">
                            @version.Source@(version.Page is null ? "" : $" p. {version.Page}")
                        </button>
                    }
                </div>
                @if (VariantVersions.Count > 1)
                {
                    <div class="source-switcher variant-switcher" aria-label="Item variants">
                        @foreach (var version in VariantVersions)
                        {
                            <button class="source-version @(version.Id == Item.Id ? "active" : "")"
                                    title="@BuildVariantTitle(version)"
                                    @onclick="() => SelectVersion(version)">
                                @version.VariantLabel
                            </button>
                        }
                    </div>
                }
                <h1>@Item.ListName</h1>
                <p>@BuildSubtitle(Item)</p>
            </div>
        </header>

        <dl class="detail-grid">
            <div><dt>Type</dt><dd>@DisplayValue(Item.TypeCode)</dd></div>
            <div><dt>Rarity</dt><dd>@DisplayValue(Item.Rarity)</dd></div>
            <div><dt>Weight</dt><dd>@FormatWeight(Item.Weight)</dd></div>
            <div><dt>Value</dt><dd>@FormatValue(Item.ValueCopper)</dd></div>
        </dl>

        @if (Item.WeaponStats is not null)
        {
            <section class="detail-section">
                <h2>Weapon</h2>
                <dl class="detail-grid item-stat-grid">
                    <div><dt>Damage</dt><dd>@DisplayValue(Item.WeaponStats.DamageDisplay)</dd></div>
                    <div><dt>Damage Type</dt><dd>@DisplayValue(Item.WeaponStats.DamageTypeCode)</dd></div>
                    <div><dt>Ability</dt><dd>@DisplayValue(Item.AttackAbilityRule)</dd></div>
                    <div><dt>Category</dt><dd>@DisplayValue(Item.WeaponStats.WeaponCategory)</dd></div>
                    <div><dt>Range</dt><dd>@DisplayValue(Item.WeaponStats.RangeDisplay)</dd></div>
                    <div><dt>Versatile</dt><dd>@DisplayValue(Item.WeaponStats.VersatileDamageDisplay)</dd></div>
                    <div><dt>Mastery</dt><dd>@DisplayValue(Item.WeaponStats.Mastery)</dd></div>
                    <div><dt>Ammo</dt><dd>@DisplayValue(Item.WeaponStats.AmmoType)</dd></div>
                </dl>
            </section>
        }

        @if (Item.ArmorStats is not null)
        {
            <section class="detail-section">
                <h2>Armor</h2>
                <dl class="detail-grid item-stat-grid">
                    <div><dt>Armor Class</dt><dd>@FormatArmorClass(Item)</dd></div>
                    <div><dt>Category</dt><dd>@FormatArmorCategory(Item.ArmorStats.ArmorCategory)</dd></div>
                    <div><dt>Strength</dt><dd>@DisplayValue(Item.ArmorStats.StrengthRequirement)</dd></div>
                    <div><dt>Stealth</dt><dd>@(Item.ArmorStats.HasStealthDisadvantage ? "Disadvantage" : "-")</dd></div>
                </dl>
            </section>
        }

        @if (Item.Bonuses.Count > 0)
        {
            <section class="detail-section">
                <h2>Bonuses</h2>
                <div class="tag-cloud inline-tag-cloud">
                    @foreach (var bonus in Item.Bonuses)
                    {
                        <span>@bonus.BonusType: @bonus.Value</span>
                    }
                </div>
            </section>
        }

        @if (Item.AttachedSpells.Count > 0)
        {
            <section class="detail-section">
                <h2>Attached Spells</h2>
                <div class="tag-cloud inline-tag-cloud">
                    @foreach (var spell in Item.AttachedSpells)
                    {
                        <span>@spell</span>
                    }
                </div>
            </section>
        }

        @if (Item.RequiresAttunement)
        {
            <section class="detail-section">
                <h2>Attunement</h2>
                <p>@(string.IsNullOrWhiteSpace(Item.AttunementText) || Item.AttunementText == "true" ? "Requires attunement." : Item.AttunementText)</p>
                @if (Item.AttunementRequirements.Count > 0)
                {
                    <div class="tag-cloud inline-tag-cloud">
                        @foreach (var requirement in Item.AttunementRequirements)
                        {
                            <span>@requirement</span>
                        }
                    </div>
                }
            </section>
        }

        @if (!string.IsNullOrWhiteSpace(Item.Description))
        {
            <section class="detail-section">
                <h2>Description</h2>
                @foreach (var paragraph in SplitParagraphs(Item.Description))
                {
                    <p><MarkupText Text="@paragraph" /></p>
                }
            </section>
        }

        <section class="tag-cloud">
            @foreach (var tag in BuildTags(Item))
            {
                <span>@tag</span>
            }
        </section>
    </section>
}

@code {
    [Parameter, EditorRequired] public ItemDefinition? Item { get; set; }
    [Parameter] public IReadOnlyList<ItemDefinition>? Versions { get; set; }
    [Parameter] public EventCallback<ItemDefinition> OnSelectVersion { get; set; }

    private IReadOnlyList<ItemDefinition> SourceVersions => Versions is { Count: > 0 } ? Versions : Item is null ? [] : [Item];
    private IReadOnlyList<ItemDefinition> ActiveSourceVersions => SelectedBaseSourceVersions.Count > 0 ? SelectedBaseSourceVersions : SourceVersions;
    private IReadOnlyList<ItemDefinition> VariantVersions => SourceVersions
        .GroupBy(item => string.IsNullOrWhiteSpace(item.VariantBaseName) ? item.Name : item.VariantBaseName, StringComparer.OrdinalIgnoreCase)
        .Select(group => group.First())
        .OrderBy(item => item.VariantLabel)
        .ToList();
    private IReadOnlyList<ItemDefinition> SelectedBaseSourceVersions => Item is null
        ? []
        : SourceVersions
            .Where(item => string.Equals(item.VariantLabel, Item.VariantLabel, StringComparison.OrdinalIgnoreCase))
            .OrderBy(item => item.Source)
            .ToList();

    private async Task SelectVersion(ItemDefinition version)
    {
        await OnSelectVersion.InvokeAsync(version);
    }

    private static string BuildSourceTitle(ItemDefinition item)
    {
        return item.Page is null ? item.Source : $"{item.Source} page {item.Page}";
    }

    private static string BuildVariantTitle(ItemDefinition item)
    {
        return string.IsNullOrWhiteSpace(item.VariantBaseName) ? item.Name : item.VariantBaseName;
    }

    private static string BuildSubtitle(ItemDefinition item)
    {
        var parts = new[] { item.Rarity, item.TypeCode, item.ItemKind }
            .Where(value => !string.IsNullOrWhiteSpace(value));
        return string.Join(" - ", parts);
    }

    private static string DisplayValue(string value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }

    private static string FormatArmorClass(ItemDefinition item)
    {
        if (item.ArmorStats?.ArmorClass is null)
        {
            return "-";
        }

        var bonus = item.Bonuses.FirstOrDefault(bonus => bonus.BonusType == "ArmorClass")?.Value;
        return string.IsNullOrWhiteSpace(bonus)
            ? item.ArmorStats.ArmorClass.Value.ToString()
            : $"{item.ArmorStats.ArmorClass.Value} ({bonus})";
    }

    private static string FormatArmorCategory(string value)
    {
        return value switch
        {
            "LA" => "Light Armor",
            "MA" => "Medium Armor",
            "HA" => "Heavy Armor",
            "S" => "Shield",
            _ => DisplayValue(value)
        };
    }

    private static string FormatWeight(double? weight)
    {
        return weight is null ? "-" : $"{weight:g} lb.";
    }

    private static string FormatValue(int? copper)
    {
        if (copper is null)
        {
            return "-";
        }

        if (copper.Value % 100 == 0)
        {
            return $"{copper.Value / 100} gp";
        }

        if (copper.Value % 10 == 0)
        {
            return $"{copper.Value / 10} sp";
        }

        return $"{copper.Value} cp";
    }

    private static IEnumerable<string> SplitParagraphs(string value)
    {
        return value.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
    }

    private static IEnumerable<string> BuildTags(ItemDefinition item)
    {
        if (item.RequiresAttunement) yield return "Attunement";
        if (item.IsWeapon) yield return "Weapon";
        if (item.IsArmor) yield return "Armor";
        if (item.IsWondrous) yield return "Wondrous";
        if (item.IsConsumable) yield return "Consumable";
        if (!string.IsNullOrWhiteSpace(item.Tier)) yield return item.Tier;
        foreach (var property in item.Properties) yield return property;
    }
}
