@page "/spells/{Id:int}"
@inject AppDatabase Database
@inject NavigationManager Navigation

<PageTitle>@spell?.Name</PageTitle>

@if (spell is null)
{
    <p class="muted">Spell wird geladen...</p>
}
else
{
    <section class="spell-detail">
        <SpellDetailContent Spell="spell"
                            Versions="versions"
                            ShowBackButton="true"
                            OnBack="OpenSpells"
                            OnTogglePrepared="TogglePrepared"
                            OnSelectVersion="SelectVersion" />
    </section>
}

@code {
    [Parameter] public int Id { get; set; }

    private Spell? spell;
    private List<Spell> versions = [];

    protected override async Task OnParametersSetAsync()
    {
        spell = await Database.GetSpellAsync(Id);
        if (spell is not null)
        {
            versions = (await Database.GetSpellVersionsAsync(spell.Name)).ToList();
        }
    }

    private async Task TogglePrepared(Spell selectedSpell)
    {
        selectedSpell.IsPrepared = !selectedSpell.IsPrepared;
        await Database.SetPreparedAsync(selectedSpell.Id, selectedSpell.IsPrepared);
    }

    private void SelectVersion(Spell selectedSpell)
    {
        spell = selectedSpell;
    }

    private void OpenSpells()
    {
        Navigation.NavigateTo("spells");
    }

}
