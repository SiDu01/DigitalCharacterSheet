@page "/spells/{Id:int}"
@inject AppDatabase Database
@inject NavigationManager Navigation
@inject RecentActivityService RecentActivity

<PageTitle>@spell?.Name</PageTitle>

@if (spell is null)
{
    <p class="muted">Spell wird geladen...</p>
}
else
{
    <section class="spell-detail">
        <SpellDetailContent Spell="spell"
                            Versions="versions"
                            ShowBackButton="true"
                            OnBack="OpenSpells"
                            OnTogglePrepared="TogglePrepared"
                            OnSelectVersion="SelectVersion"
                            OnToggleBookmark="ToggleBookmark"
                            IsBookmarked="@IsCurrentSpellBookmarked" />
    </section>
}

@code {
    [Parameter] public int Id { get; set; }

    private Spell? spell;
    private List<Spell> versions = [];
    private bool IsCurrentSpellBookmarked => spell is not null && RecentActivity.IsBookmarked("Spell", spell.Id);

    protected override async Task OnParametersSetAsync()
    {
        spell = await Database.GetSpellAsync(Id);
        if (spell is not null)
        {
            versions = (await Database.GetSpellVersionsAsync(spell.Name)).ToList();
            RecentActivity.Track("Spell", spell.Id, spell.Name, $"{spell.LevelDisplay} {spell.School} - {spell.Source}", $"spells/{spell.Id}");
        }
    }

    private async Task TogglePrepared(Spell selectedSpell)
    {
        selectedSpell.IsPrepared = !selectedSpell.IsPrepared;
        await Database.SetPreparedAsync(selectedSpell.Id, selectedSpell.IsPrepared);
    }

    private void SelectVersion(Spell selectedSpell)
    {
        spell = selectedSpell;
        RecentActivity.Track("Spell", spell.Id, spell.Name, $"{spell.LevelDisplay} {spell.School} - {spell.Source}", $"spells/{spell.Id}");
    }

    private void ToggleBookmark(Spell selectedSpell)
    {
        RecentActivity.ToggleBookmark("Spell", selectedSpell.Id, selectedSpell.Name, $"{selectedSpell.LevelDisplay} {selectedSpell.School} - {selectedSpell.Source}", $"spells/{selectedSpell.Id}");
    }

    private void OpenSpells()
    {
        Navigation.NavigateTo("spells");
    }

}
