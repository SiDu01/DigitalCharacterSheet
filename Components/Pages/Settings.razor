@page "/settings"
@inject AppDatabase Database
@inject IJSRuntime JsRuntime
@inject TextBadgeSettingsService TextBadgeSettings

<PageTitle>Settings</PageTitle>

<section class="settings-page">
    <header class="page-header">
        <div>
            <p class="eyebrow">Settings</p>
            <h1>Settings</h1>
        </div>
    </header>

    <nav class="tab-bar" aria-label="Settings sections">
        <button type="button" class="tab-button @(activeTab == "Appearance" ? "active" : "")" @onclick='() => SetActiveTab("Appearance")'>Appearance</button>
        <button type="button" class="tab-button @(activeTab == "Sources" ? "active" : "")" @onclick='() => SetActiveTab("Sources")'>Sources</button>
        <button type="button" class="tab-button @(activeTab == "TextBadges" ? "active" : "")" @onclick='() => SetActiveTab("TextBadges")'>Text Badges</button>
        <button type="button" class="tab-button @(activeTab == "Data" ? "active" : "")" @onclick='() => SetActiveTab("Data")'>Data</button>
    </nav>

    @if (activeTab == "Appearance")
    {
        <section class="settings-panel">
            <header>
                <p class="eyebrow">Theme</p>
                <h2>Color Theme</h2>
            </header>

            <section class="theme-grid">
                <button type="button" class="theme-card @(selectedTheme == "classic" ? "active" : "")" @onclick='async () => await SelectTheme("classic")'>
                    <span class="theme-preview classic-preview"></span>
                    <strong>Classic</strong>
                    <small>Current light app style</small>
                </button>

                <button type="button" class="theme-card @(selectedTheme == "leather" ? "active" : "")" @onclick='async () => await SelectTheme("leather")'>
                    <span class="theme-preview leather-preview"></span>
                    <strong>Leather Book</strong>
                    <small>Dark warm leather and brass</small>
                </button>
            </section>
        </section>
    }
    else if (activeTab == "Sources")
    {
        <section class="settings-panel">
            <header class="settings-panel-header">
                <div>
                    <p class="eyebrow">Content</p>
                    <h2>Sources</h2>
                </div>
                <button type="button" class="text-button no-margin" @onclick="ResetSources">Reset</button>
            </header>

            @if (isLoadingSources)
            {
                <p class="muted">Sources werden geladen...</p>
            }
            else
            {
                <section class="source-settings-list">
                    @for (var index = 0; index < sourceSettings.Count; index++)
                    {
                        var source = sourceSettings[index];
                        <article class="source-settings-row @(source.IsEnabled ? "" : "disabled")">
                            <label class="switch-toggle">
                                <input type="checkbox" checked="@source.IsEnabled" @onchange="async args => await SetSourceEnabled(source, args.Value is bool value && value)" />
                                <span>@source.DisplayName</span>
                            </label>
                            <span class="source-code">@source.SourceCode</span>
                            <div class="source-order-actions">
                                <button type="button" class="mini-button source-move-button" disabled="@(index == 0)" @onclick="async () => await MoveSource(source, -1)">Up</button>
                                <button type="button" class="mini-button source-move-button" disabled="@(index == sourceSettings.Count - 1)" @onclick="async () => await MoveSource(source, 1)">Down</button>
                            </div>
                        </article>
                    }
                </section>
            }

            @if (!string.IsNullOrWhiteSpace(sourceMessage))
            {
                <p class="muted">@sourceMessage</p>
            }
        </section>
    }
    else if (activeTab == "TextBadges")
    {
        <section class="settings-panel">
            <header class="settings-panel-header">
                <div>
                    <p class="eyebrow">Reading Aid</p>
                    <h2>Text Badges</h2>
                </div>
                <button type="button" class="text-button no-margin" @onclick="ResetTextBadges">Reset</button>
            </header>

            <form class="text-badge-add" @onsubmit="AddTextBadge" @onsubmit:preventDefault>
                <input type="text" placeholder="New word or phrase" @bind="newTextBadgePhrase" />
                <button type="submit" class="primary-action">Add</button>
            </form>

            @if (!string.IsNullOrWhiteSpace(textBadgeMessage))
            {
                <p class="muted">@textBadgeMessage</p>
            }

            <section class="text-badge-settings-list">
                @foreach (var group in textBadgeRules.GroupBy(rule => rule.Category).OrderBy(group => group.Key))
                {
                    <article class="text-badge-group">
                        <h3>@group.Key</h3>
                        <div class="text-badge-rule-grid">
                            @foreach (var rule in group.OrderBy(rule => rule.Phrase))
                            {
                                <div class="text-badge-rule-row @(rule.IsEnabled ? "" : "disabled")">
                                    <label class="switch-toggle">
                                        <input type="checkbox" checked="@rule.IsEnabled" @onchange="args => SetTextBadgeEnabled(rule, args.Value is bool value && value)" />
                                        <span><MarkupText Text="@rule.Phrase" /></span>
                                    </label>
                                    @if (rule.Category == "Custom")
                                    {
                                        <button type="button" class="mini-button danger-action" @onclick="() => DeleteTextBadge(rule)">Delete</button>
                                    }
                                </div>
                            }
                        </div>
                    </article>
                }
            </section>
        </section>
    }
    else
    {
        <section class="settings-panel">
            <header>
                <p class="eyebrow">Data</p>
                <h2>Data Settings</h2>
            </header>
            <div class="settings-actions">
                <button type="button" class="text-button no-margin" disabled="@isExporting" @onclick="ExportCharacters">
                    Export Characters
                </button>
                <button type="button" class="text-button no-margin" disabled="@isImporting" @onclick="ImportCharacters">
                    Import Characters
                </button>
            </div>
            @if (!string.IsNullOrWhiteSpace(dataMessage))
            {
                <p class="muted">@dataMessage</p>
            }
        </section>
    }
</section>

@code {
    private string activeTab = "Appearance";
    private string selectedTheme = "classic";
    private bool isExporting;
    private bool isImporting;
    private bool isLoadingSources = true;
    private string dataMessage = "";
    private string sourceMessage = "";
    private string textBadgeMessage = "";
    private string newTextBadgePhrase = "";
    private List<SourceSetting> sourceSettings = [];
    private List<TextBadgeRule> textBadgeRules = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadSourceSettings();
        LoadTextBadgeSettings();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        selectedTheme = await JsRuntime.InvokeAsync<string>("digitalCharacterSheet.getTheme");
        StateHasChanged();
    }

    private void SetActiveTab(string tab)
    {
        activeTab = tab;
    }

    private async Task SelectTheme(string theme)
    {
        selectedTheme = theme == "leather" ? "leather" : "classic";
        await JsRuntime.InvokeVoidAsync("digitalCharacterSheet.setTheme", selectedTheme);
    }

    private async Task LoadSourceSettings()
    {
        try
        {
            isLoadingSources = true;
            sourceSettings = (await Database.GetSourceSettingsAsync()).ToList();
        }
        catch (Exception exception)
        {
            sourceMessage = $"Sources konnten nicht geladen werden: {exception.Message}";
        }
        finally
        {
            isLoadingSources = false;
        }
    }

    private async Task SetSourceEnabled(SourceSetting source, bool isEnabled)
    {
        source.IsEnabled = isEnabled;
        await Database.SetSourceEnabledAsync(source.SourceCode, isEnabled);
        sourceMessage = isEnabled
            ? $"{source.SourceCode} ist aktiv."
            : $"{source.SourceCode} ist deaktiviert.";
    }

    private async Task MoveSource(SourceSetting source, int direction)
    {
        await Database.MoveSourceAsync(source.SourceCode, direction);
        await LoadSourceSettings();
        sourceMessage = $"{source.SourceCode} Priorität aktualisiert.";
    }

    private async Task ResetSources()
    {
        await Database.ResetSourceSettingsAsync();
        await LoadSourceSettings();
        sourceMessage = "Source-Einstellungen zurückgesetzt.";
    }

    private void LoadTextBadgeSettings()
    {
        textBadgeRules = TextBadgeSettings.GetRules().Select(CloneTextBadgeRule).ToList();
    }

    private void SetTextBadgeEnabled(TextBadgeRule rule, bool isEnabled)
    {
        TextBadgeSettings.SetEnabled(rule.Id, isEnabled);
        LoadTextBadgeSettings();
        textBadgeMessage = isEnabled
            ? $"{rule.Phrase} wird als Badge angezeigt."
            : $"{rule.Phrase} wird nicht mehr als Badge angezeigt.";
    }

    private void AddTextBadge()
    {
        if (TextBadgeSettings.AddRule(newTextBadgePhrase))
        {
            textBadgeMessage = $"{newTextBadgePhrase.Trim()} wurde hinzugefuegt.";
            newTextBadgePhrase = "";
        }
        else
        {
            textBadgeMessage = "Diese Wortgruppe existiert bereits oder ist leer.";
        }

        LoadTextBadgeSettings();
    }

    private void DeleteTextBadge(TextBadgeRule rule)
    {
        TextBadgeSettings.DeleteRule(rule.Id);
        LoadTextBadgeSettings();
        textBadgeMessage = $"{rule.Phrase} wurde geloescht.";
    }

    private void ResetTextBadges()
    {
        TextBadgeSettings.ResetDefaults();
        LoadTextBadgeSettings();
        textBadgeMessage = "Text-Badges wurden zurueckgesetzt.";
    }

    private static TextBadgeRule CloneTextBadgeRule(TextBadgeRule rule)
    {
        return new TextBadgeRule
        {
            Id = rule.Id,
            Phrase = rule.Phrase,
            IsEnabled = rule.IsEnabled,
            Category = rule.Category
        };
    }

    private async Task ExportCharacters()
    {
        try
        {
            isExporting = true;
            dataMessage = "";
            var fileName = $"characters-{DateTime.Now:yyyyMMdd-HHmmss}.json";
            var exportPath = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.LocalApplicationData), fileName);
            var savedPath = await Database.ExportCharactersAsync(exportPath);
            dataMessage = $"Export saved: {savedPath}";
        }
        catch (Exception exception)
        {
            dataMessage = $"Export failed: {exception.Message}";
        }
        finally
        {
            isExporting = false;
        }
    }

    private async Task ImportCharacters()
    {
        try
        {
            isImporting = true;
            dataMessage = "";
            var result = await Microsoft.Maui.Storage.FilePicker.Default.PickAsync(new Microsoft.Maui.Storage.PickOptions
            {
                PickerTitle = "Select character export",
                FileTypes = new Microsoft.Maui.Storage.FilePickerFileType(new Dictionary<Microsoft.Maui.Devices.DevicePlatform, IEnumerable<string>>
                {
                    { Microsoft.Maui.Devices.DevicePlatform.Android, new[] { "application/json", "text/plain" } },
                    { Microsoft.Maui.Devices.DevicePlatform.WinUI, new[] { ".json" } }
                })
            });

            if (result is null)
            {
                dataMessage = "Import cancelled.";
                return;
            }

            var importPath = result.FullPath;
            if (string.IsNullOrWhiteSpace(importPath) || !File.Exists(importPath))
            {
                importPath = Path.Combine(FileSystem.CacheDirectory, $"character-import-{DateTime.Now:yyyyMMdd-HHmmss}.json");
                await using var source = await result.OpenReadAsync();
                await using var target = File.Create(importPath);
                await source.CopyToAsync(target);
            }

            var importedCount = await Database.ImportCharactersAsync(importPath);
            dataMessage = $"Imported {importedCount} character(s).";
        }
        catch (Exception exception)
        {
            dataMessage = $"Import failed: {exception.Message}";
        }
        finally
        {
            isImporting = false;
        }
    }
}
