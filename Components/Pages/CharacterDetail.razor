    private string BuildInventoryStats(CharacterInventoryItem item)
    {
        var definition = item.ItemDefinition;
        if (definition?.WeaponStats is not null)
        {
            return $"Attack {FormatModifier(GetWeaponAttackBonus(definition))} / {BuildWeaponDamage(definition)}";
        }

        if (definition?.ArmorStats is not null)
        {
            return IsShield(definition)
                ? $"+{GetShieldArmorBonus(definition)} AC"
                : $"AC {BuildArmorValueDisplay(definition)}";
        }

        return "";
    }

    private string FormatWeaponAction(CharacterInventoryItem item)
    {
        var definition = item.ItemDefinition;
        if (definition?.WeaponStats is null)
        {
            return "";
        }

        var parts = new List<string>
        {
            $"Hit {FormatModifier(GetWeaponAttackBonus(definition))}",
            BuildWeaponDamage(definition)
        };

        if (!string.IsNullOrWhiteSpace(definition.WeaponStats.RangeDisplay))
        {
            parts.Add(definition.WeaponStats.RangeDisplay);
        }

        if (!string.IsNullOrWhiteSpace(definition.WeaponStats.Mastery))
        {
            parts.Add($"Mastery {definition.WeaponStats.Mastery}");
        }

        return string.Join(" / ", parts.Where(part => !string.IsNullOrWhiteSpace(part)));
    }

    private string BuildWeaponActionDescription(CharacterInventoryItem item)
    {
        var definition = item.ItemDefinition;
        if (definition?.WeaponStats is null)
        {
            return "Equipped weapon attack.";
        }

        var parts = new List<string>
        {
            $"Attack bonus: {FormatModifier(GetWeaponAttackBonus(definition))}.",
            $"Damage: {BuildWeaponDamage(definition)}."
        };

        if (!string.IsNullOrWhiteSpace(definition.WeaponStats.VersatileDamageDisplay))
        {
            parts.Add($"Versatile: {definition.WeaponStats.VersatileDamageDisplay}.");
        }

        if (!string.IsNullOrWhiteSpace(definition.WeaponStats.RangeDisplay))
        {
            parts.Add($"Range: {definition.WeaponStats.RangeDisplay}.");
        }

        if (!string.IsNullOrWhiteSpace(definition.WeaponStats.Mastery))
        {
            parts.Add($"Mastery: {definition.WeaponStats.Mastery}.");
        }

        if (definition.Properties.Count > 0)
        {
            parts.Add($"Properties: {string.Join(", ", definition.Properties)}.");
        }

        return string.Join(" ", parts);
    }

    private IEnumerable<string> BuildWeaponActionBadges(CharacterInventoryItem item)
    {
        var definition = item.ItemDefinition;
        if (definition?.WeaponStats is null)
        {
            yield return "Weapon";
            yield break;
        }

        yield return "Weapon";
        yield return $"Hit {FormatModifier(GetWeaponAttackBonus(definition))}";
        var damage = BuildWeaponDamage(definition);
        if (!string.IsNullOrWhiteSpace(damage))
        {
            yield return damage;
        }

        if (!string.IsNullOrWhiteSpace(definition.WeaponStats.RangeDisplay))
        {
            yield return definition.WeaponStats.RangeDisplay;
        }

        if (!string.IsNullOrWhiteSpace(definition.WeaponStats.Mastery))
        {
            yield return $"Mastery {definition.WeaponStats.Mastery}";
        }
    }

    private static string BuildSpellActionSummary(Spell spell)
    {
        var parts = new List<string>
        {
            spell.LevelDisplay,
            spell.CastingTimeDisplay,
            spell.RangeDisplay
        };

        if (spell.RequiresConcentration)
        {
            parts.Add("Concentration");
        }

        return string.Join(" / ", parts.Where(part => !string.IsNullOrWhiteSpace(part)));
    }

    private static IEnumerable<string> BuildSpellActionBadges(Spell spell)
    {
        yield return spell.Level == 0 ? "Cantrip" : $"Level {spell.Level}";
        yield return "Spell";
        if (!string.IsNullOrWhiteSpace(spell.RangeDisplay))
        {
            yield return spell.RangeDisplay;
        }

        if (spell.SpellAttackTypes.Count > 0)
        {
            yield return "Attack";
        }

        foreach (var save in spell.SavingThrows.Take(2))
        {
            yield return $"{save.ToUpperInvariant()} save";
        }

        foreach (var damageType in spell.DamageTypes.Take(2))
        {
            yield return damageType;
        }
    }

    private int GetWeaponAttackBonus(ItemDefinition item)
    {
        return ProficiencyBonus + GetWeaponAbilityModifier(item) + GetItemBonus(item, "Weapon", "WeaponAttack");
    }

    private int GetWeaponAbilityModifier(ItemDefinition item)
    {
        return item.AttackAbilityRule switch
        {
            "DEX" => GetAbilityModifier("dex"),
            "STR or DEX" => Math.Max(GetAbilityModifier("str"), GetAbilityModifier("dex")),
            _ => GetAbilityModifier("str")
        };
    }

    private string BuildWeaponDamage(ItemDefinition item)
    {
        if (item.WeaponStats is null)
        {
            return "";
        }

        var damage = item.WeaponStats.DamageDisplay;
        if (string.IsNullOrWhiteSpace(damage))
        {
            return "";
        }

        var modifier = GetWeaponAbilityModifier(item) + GetItemBonus(item, "Weapon", "WeaponDamage");
        return $"{damage} {FormatModifier(modifier)}".Trim();
    }

    private ArmorCalculation CalculateArmorClass()
    {
        var dexterityModifier = GetAbilityModifier("dex");
        var itemArmorBonus = GetActiveItemBonus("ArmorClass", item => item.ItemDefinition is not null && !IsShield(item.ItemDefinition) && item.ItemDefinition.ArmorStats is null);
        var shieldBonus = inventoryItems
            .Where(item => item.IsEquipped && item.ItemDefinition is not null && IsShield(item.ItemDefinition))
            .Sum(item => GetShieldArmorBonus(item.ItemDefinition!));

        var baseArmor = inventoryItems
            .Where(item => item.IsEquipped && item.ItemDefinition?.ArmorStats is not null && !IsShield(item.ItemDefinition))
            .Select(item => new ArmorCalculation(
                CalculateArmorItemClass(item.ItemDefinition!, dexterityModifier) + shieldBonus + itemArmorBonus,
                $"{item.DisplayName}{(shieldBonus > 0 ? " + shield" : "")}{(itemArmorBonus != 0 ? " + magic" : "")}"))
            .OrderByDescending(result => result.Value)
            .FirstOrDefault();

        if (baseArmor is not null)
        {
            return baseArmor;
        }

        return new ArmorCalculation(
            10 + dexterityModifier + shieldBonus + itemArmorBonus,
            $"{(shieldBonus > 0 ? "Unarmored + shield" : "Unarmored base")}{(itemArmorBonus != 0 ? " + magic" : "")}");
    }

    private static int CalculateArmorItemClass(ItemDefinition item, int dexterityModifier)
    {
        var armorClass = item.ArmorStats?.ArmorClass ?? 10;
        armorClass += item.ArmorStats?.ArmorCategory switch
        {
            "LA" => dexterityModifier,
            "MA" => Math.Min(dexterityModifier, 2),
            "HA" => 0,
            _ => dexterityModifier
        };

        return armorClass + GetItemBonus(item, "ArmorClass");
    }

    private static int GetShieldArmorBonus(ItemDefinition item)
    {
        var baseBonus = item.ArmorStats?.ArmorClass ?? 2;
        return baseBonus + GetItemBonus(item, "ArmorClass");
    }

    private static bool IsShield(ItemDefinition item)
    {
        return item.ArmorStats?.ArmorCategory == "S"
            || item.TypeCode == "S"
            || item.Name.Contains("shield", StringComparison.OrdinalIgnoreCase);
    }

    private static string BuildArmorValueDisplay(ItemDefinition item)
    {
        if (item.ArmorStats is null)
        {
            return "";
        }

        var bonus = GetItemBonus(item, "ArmorClass");
        var bonusText = bonus == 0 ? "" : $" {FormatModifier(bonus)}";
        return $"{item.ArmorStats.ArmorClass}{bonusText}".Trim();
    }

    private static int ParseSignedBonus(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return 0;
        }

        var cleaned = value.Trim().Replace("+", "");
        return int.TryParse(cleaned, out var parsed) ? parsed : 0;
    }

    private static string FormatItemRarity(string rarity)
    {
        return rarity switch
        {
            "" => "",
            "none" => "Common",
            _ => System.Globalization.CultureInfo.InvariantCulture.TextInfo.ToTitleCase(rarity.Replace("_", " "))
        };
    }

    private static int AbilityModifier(int abilityScore)
    {
        return (int)Math.Floor((abilityScore - 10) / 2.0);
    }

    private static string FormatModifier(int modifier)
    {
        return modifier >= 0 ? $"+{modifier}" : modifier.ToString();
    }

    private static string FormatSpellLevel(int level)
    {
        return level == 0 ? "Cantrips" : $"Level {level}";
    }

    private static string GetSpellLevelClass(int level)
    {
        return $"spell-level-badge level-{level}";
    }

    private static string FormatProficiency(CharacterSavingThrow savingThrow)
    {
        return FormatProficiency(savingThrow.IsProficient, savingThrow.RollMode, savingThrow.Notes);
    }

    private static string FormatProficiency(CharacterSkill skill)
    {
        return FormatProficiency(skill.IsProficient, skill.RollMode, skill.Notes);
    }

    private static string FormatProficiency(bool isProficient, string rollMode, string notes)
    {
        var parts = new List<string>();
        if (isProficient)
        {
            parts.Add("Prof");
        }

        if (rollMode is "Advantage" or "Disadvantage")
        {
            parts.Add(rollMode);
        }

        if (!string.IsNullOrWhiteSpace(notes))
        {
            parts.Add(notes);
        }

        return parts.Count == 0 ? "-" : string.Join(" / ", parts);
    }

    private int GetSavingThrowModifier(CharacterSavingThrow savingThrow)
    {
        return GetAbilityModifier(savingThrow.AbilityCode)
            + (savingThrow.IsProficient ? ProficiencyBonus : 0)
            + GetActiveItemBonus("SavingThrow");
    }

    private int GetSkillModifier(CharacterSkill skill)
    {
        return GetAbilityModifier(skill.AbilityCode) + (skill.ProficiencyLevel switch
        {
            "Half" => ProficiencyBonus / 2,
            "Expertise" => ProficiencyBonus * 2,
            "Proficient" => ProficiencyBonus,
            _ => skill.IsProficient ? ProficiencyBonus : 0
        }) + GetActiveItemBonus("AbilityCheck");
    }

    private static bool SkillHasTraining(CharacterSkill skill)
    {
        return skill.IsProficient || skill.ProficiencyLevel is "Half" or "Proficient" or "Expertise";
    }

    private int GetSkillModifierByName(string name)
    {
        var skill = character?.Skills.FirstOrDefault(skill => string.Equals(skill.Name, name, StringComparison.OrdinalIgnoreCase));
        return skill is null ? 0 : GetSkillModifier(skill);
    }

    private int GetAbilityCheckModifier(string abilityCode)
    {
        return GetAbilityModifier(abilityCode) + GetActiveItemBonus("AbilityCheck");
    }

    private int GetFeatureInitiativeBonus()
    {
        var bonus = 0;
        foreach (var feature in sheetFeatureGroups.SelectMany(group => group.Levels).SelectMany(level => level.Features))
        {
            var mapping = DescriptionRuleMapper.MapFeature(feature.Name, feature.Paragraphs);
            foreach (var effect in mapping.Effects.Where(effect => effect.EffectType == "InitiativeAbilityBonus"))
            {
                bonus += GetAbilityModifier(effect.TargetKey);
            }
        }

        return bonus;
    }

    private string BuildInitiativeSource()
    {
        var parts = new List<string> { HasInitiativeAdvantage ? "DEX + ADV" : "DEX" };
        if (GetFeatureInitiativeBonus() != 0)
        {
            parts.Add("features");
        }

        if (GetActiveItemBonus("Initiative") != 0 || GetActiveItemBonus("AbilityCheck") != 0)
        {
            parts.Add("items");
        }

        return string.Join(" + ", parts);
    }

    private int GetAbilityModifier(string abilityCode)
    {
        if (character is null)
        {
            return 0;
        }

        var score = abilityCode switch
        {
            "str" => character.Strength,
            "dex" => character.Dexterity,
            "con" => character.Constitution,
            "int" => character.Intelligence,
            "wis" => character.Wisdom,
            "cha" => character.Charisma,
            _ => 10
        };

        return AbilityModifier(score);
    }

    private int GetActiveItemBonus(string bonusType)
    {
        return GetActiveItemBonus(bonusType, _ => true);
    }

    private int GetActiveItemBonus(string bonusType, Func<CharacterInventoryItem, bool> itemFilter)
    {
        var inventoryItemIds = inventoryItems
            .Where(itemFilter)
            .Select(item => item.Id)
            .ToHashSet();

        return ActiveItemEffects
            .Where(effect => inventoryItemIds.Contains(effect.InventoryItemId))
            .Where(effect => ItemEffectMatchesBonus(effect, bonusType))
            .Sum(effect => effect.Value);
    }

    private static int GetItemBonus(ItemDefinition item, params string[] bonusTypes)
    {
        return ItemEffectService.GetDefinitionBonus(item, bonusTypes);
    }

    private static bool IsItemBonusActive(CharacterInventoryItem item)
    {
        return ItemEffectService.IsActive(item);
    }

    private static bool ItemEffectMatchesBonus(ItemEffect effect, string bonusType)
    {
        return bonusType switch
        {
            "ArmorClass" => effect.EffectType == "ArmorClassBonus",
            "SavingThrow" => effect.EffectType == "SavingThrowBonus",
            "ConcentrationSavingThrow" => effect.EffectType == "ConcentrationSavingThrowBonus",
            "AbilityCheck" => effect.EffectType == "AbilityCheckBonus",
            "Weapon" or "WeaponAttack" => effect.EffectType == "WeaponAttackBonus",
            "WeaponDamage" => effect.EffectType == "WeaponDamageBonus",
            "SpellAttack" => effect.EffectType == "SpellAttackBonus",
            "SpellSaveDc" => effect.EffectType == "SpellSaveDcBonus",
            "SpellDamage" => effect.EffectType == "SpellDamageBonus",
            "ProficiencyBonus" => effect.EffectType == "ProficiencyBonus",
            "Initiative" => effect.EffectType == "InitiativeBonus",
            _ => string.Equals(effect.EffectType, $"{bonusType}Bonus", StringComparison.OrdinalIgnoreCase)
        };
    }

    private IEnumerable<ItemRuleEffect> BuildCharacterRuleEffects()
    {
        if (character is null)
        {
            yield break;
        }

        var race = character.RaceDefinitionId is null
            ? raceDefinitions.FirstOrDefault(definition =>
                string.Equals(definition.Name, character.RaceName, StringComparison.OrdinalIgnoreCase)
                && (string.IsNullOrWhiteSpace(character.RaceSource) || string.Equals(definition.Source, character.RaceSource, StringComparison.OrdinalIgnoreCase)))
            : raceDefinitions.FirstOrDefault(definition => definition.Id == character.RaceDefinitionId.Value);
        foreach (var effect in BuildDefinitionRuleEffects(race?.RawJson, BuildSourceName("Race", race?.Name), $"Race:{race?.Id}", character.RaceChoicesJson))
        {
            yield return effect;
        }

        var subrace = character.SubraceDefinitionId is null
            ? null
            : subraceDefinitions.FirstOrDefault(definition => definition.Id == character.SubraceDefinitionId.Value);
        foreach (var effect in BuildDefinitionRuleEffects(subrace?.RawJson, BuildSourceName("Race version", subrace?.Name ?? character.SubraceName), $"Subrace:{subrace?.Id}", character.RaceChoicesJson))
        {
            yield return effect;
        }

        var background = character.BackgroundDefinitionId is null
            ? backgroundDefinitions.FirstOrDefault(definition =>
                string.Equals(definition.Name, character.BackgroundName, StringComparison.OrdinalIgnoreCase)
                && (string.IsNullOrWhiteSpace(character.BackgroundSource) || string.Equals(definition.Source, character.BackgroundSource, StringComparison.OrdinalIgnoreCase)))
            : backgroundDefinitions.FirstOrDefault(definition => definition.Id == character.BackgroundDefinitionId.Value);
        foreach (var effect in BuildDefinitionRuleEffects(background?.RawJson, BuildSourceName("Background", background?.Name), $"Background:{background?.Id}", character.BackgroundChoicesJson))
        {
            yield return effect;
        }

        foreach (var characterFeat in character.Feats)
        {
            var feat = featDefinitions.FirstOrDefault(definition => definition.Id == characterFeat.FeatDefinitionId)
                ?? featDefinitions.FirstOrDefault(definition =>
                    string.Equals(definition.Name, characterFeat.FeatName, StringComparison.OrdinalIgnoreCase)
                    && (string.IsNullOrWhiteSpace(characterFeat.FeatSource) || string.Equals(definition.Source, characterFeat.FeatSource, StringComparison.OrdinalIgnoreCase)));
            foreach (var effect in BuildDefinitionRuleEffects(feat?.RawJson, BuildSourceName("Feat", feat?.Name ?? characterFeat.FeatName), $"Feat:{feat?.Id}", character.FeatChoicesJson))
            {
                yield return effect;
            }
        }

        foreach (var group in sheetFeatureGroups)
        {
            foreach (var feature in group.Levels.SelectMany(level => level.Features))
            {
                foreach (var effect in BuildTextRuleEffects(feature.Paragraphs, BuildSourceName(group.Kind, feature.Name)))
                {
                    yield return effect;
                }
            }
        }
    }

    private static IEnumerable<ItemRuleEffect> BuildDefinitionRuleEffects(string? rawJson, string sourceName, string sourceKey, string choicesJson)
    {
        if (string.IsNullOrWhiteSpace(rawJson))
        {
            yield break;
        }

        using var document = System.Text.Json.JsonDocument.Parse(rawJson);
        foreach (var effect in BuildChoiceRuleEffects(rawJson, sourceKey, sourceName, choicesJson))
        {
            yield return effect;
        }

        foreach (var effect in BuildJsonRuleEffects(document.RootElement, sourceName))
        {
            yield return effect;
        }

        if (document.RootElement.TryGetProperty("entries", out var entries))
        {
            foreach (var effect in BuildTextRuleEffects(ExtractParagraphs(entries), sourceName))
            {
                yield return effect;
            }
        }
    }

    private static IEnumerable<ItemRuleEffect> BuildChoiceRuleEffects(string rawJson, string sourceKey, string sourceName, string choicesJson)
    {
        var selectedChoices = CharacterDefenseChoiceService.ReadSelectedChoices(choicesJson);
        foreach (var requirement in CharacterDefenseChoiceService.BuildRequirements(rawJson, sourceKey, sourceName))
        {
            if (!selectedChoices.TryGetValue(requirement.Key, out var values))
            {
                continue;
            }

            foreach (var value in values.Take(requirement.Count))
            {
                yield return new ItemRuleEffect(requirement.EffectType, NormalizeRuleTarget(value), FormatRuleTarget(value), sourceName);
            }
        }
    }

    private static IEnumerable<ItemRuleEffect> BuildJsonRuleEffects(System.Text.Json.JsonElement root, string sourceName)
    {
        foreach (var target in ReadRuleEffectTargets(root, "resist"))
        {
            yield return new ItemRuleEffect("Resistance", NormalizeRuleTarget(target), FormatRuleTarget(target), sourceName);
        }

        foreach (var target in ReadRuleEffectTargets(root, "immune"))
        {
            yield return new ItemRuleEffect("Immunity", NormalizeRuleTarget(target), FormatRuleTarget(target), sourceName);
        }

        foreach (var target in ReadRuleEffectTargets(root, "conditionImmune"))
        {
            yield return new ItemRuleEffect("Condition Immunity", NormalizeRuleTarget(target), FormatRuleTarget(target), sourceName);
        }

        foreach (var target in ReadRuleEffectTargets(root, "vulnerable"))
        {
            yield return new ItemRuleEffect("Vulnerability", NormalizeRuleTarget(target), FormatRuleTarget(target), sourceName);
        }
    }

    private static IEnumerable<ItemRuleEffect> BuildTextRuleEffects(IEnumerable<string> paragraphs, string sourceName)
    {
        foreach (var paragraph in paragraphs.Select(CleanMarkup))
        {
            foreach (var target in ExtractDamageTargets(paragraph, @"\byou (?:have|gain) resistance to ([^.]+?) damage\b"))
            {
                yield return new ItemRuleEffect("Resistance", NormalizeRuleTarget(target), FormatRuleTarget(target), sourceName);
            }

            foreach (var target in ExtractDamageTargets(paragraph, @"\byou (?:are|become) immune to ([^.]+?) damage\b"))
            {
                yield return new ItemRuleEffect("Immunity", NormalizeRuleTarget(target), FormatRuleTarget(target), sourceName);
            }

            foreach (var target in ExtractConditionTargets(paragraph, @"\byou (?:are|become) immune to (?:the )?([^.]+?) condition"))
            {
                yield return new ItemRuleEffect("Condition Immunity", NormalizeRuleTarget(target), FormatRuleTarget(target), sourceName);
            }

            foreach (var target in ExtractConditionTargets(paragraph, @"\byou can't be ([a-zA-Z ]+?)(?:\.|,| and| or|$)"))
            {
                yield return new ItemRuleEffect("Condition Immunity", NormalizeRuleTarget(target), FormatRuleTarget(target), sourceName);
            }

            foreach (var target in ExtractDamageTargets(paragraph, @"\byou (?:are|become) vulnerable to ([^.]+?) damage\b"))
            {
                yield return new ItemRuleEffect("Vulnerability", NormalizeRuleTarget(target), FormatRuleTarget(target), sourceName);
            }
        }
    }

    private static IEnumerable<string> ExtractDamageTargets(string text, string pattern)
    {
        foreach (System.Text.RegularExpressions.Match match in System.Text.RegularExpressions.Regex.Matches(text, pattern, System.Text.RegularExpressions.RegexOptions.IgnoreCase))
        {
            foreach (var target in SplitRuleTargets(match.Groups[1].Value))
            {
                yield return target;
            }
        }
    }

    private static IEnumerable<string> ExtractConditionTargets(string text, string pattern)
    {
        var knownConditions = CombatConditionPlaceholders.Append("Exhaustion").Append("Disease").ToList();
        foreach (System.Text.RegularExpressions.Match match in System.Text.RegularExpressions.Regex.Matches(text, pattern, System.Text.RegularExpressions.RegexOptions.IgnoreCase))
        {
            var value = match.Groups[1].Value;
            foreach (var condition in knownConditions.Where(condition => value.Contains(condition, StringComparison.OrdinalIgnoreCase)))
            {
                yield return condition;
            }
        }
    }

    private static IEnumerable<string> SplitRuleTargets(string value)
    {
        var normalized = value
            .Replace(" and ", ",", StringComparison.OrdinalIgnoreCase)
            .Replace(" or ", ",", StringComparison.OrdinalIgnoreCase);

        foreach (var part in normalized.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        {
            var cleaned = part
                .Replace("damage", "", StringComparison.OrdinalIgnoreCase)
                .Replace("from nonmagical attacks", "", StringComparison.OrdinalIgnoreCase)
                .Replace("from nonmagical weapons", "", StringComparison.OrdinalIgnoreCase)
                .Trim();
            if (!string.IsNullOrWhiteSpace(cleaned))
            {
                yield return cleaned;
            }
        }
    }

    private static string BuildSourceName(string sourceType, string? name)
    {
        return string.IsNullOrWhiteSpace(name) ? sourceType : $"{sourceType}: {name}";
    }

    private static IEnumerable<string> ReadRuleEffectTargets(System.Text.Json.JsonElement root, string propertyName)
    {
        if (!root.TryGetProperty(propertyName, out var property))
        {
            yield break;
        }

        foreach (var target in ReadRuleEffectTargetElement(property))
        {
            if (!string.IsNullOrWhiteSpace(target))
            {
                yield return target;
            }
        }
    }

    private static IEnumerable<string> ReadRuleEffectTargetElement(System.Text.Json.JsonElement element)
    {
        switch (element.ValueKind)
        {
            case System.Text.Json.JsonValueKind.String:
                yield return element.GetString() ?? "";
                break;
            case System.Text.Json.JsonValueKind.Array:
                foreach (var child in element.EnumerateArray())
                {
                    foreach (var target in ReadRuleEffectTargetElement(child))
                    {
                        yield return target;
                    }
                }
                break;
            case System.Text.Json.JsonValueKind.Object:
                if (element.TryGetProperty("choose", out _))
                {
                    yield break;
                }

                foreach (var property in element.EnumerateObject())
                {
                    if (property.Value.ValueKind == System.Text.Json.JsonValueKind.True)
                    {
                        yield return property.Name;
                    }
                    else
                    {
                        foreach (var target in ReadRuleEffectTargetElement(property.Value))
                        {
                            yield return target;
                        }
                    }
                }
                break;
        }
    }

    private static string NormalizeRuleTarget(string target)
    {
        return CleanMarkup(target).Trim().ToLowerInvariant();
    }

    private static string FormatRuleTarget(string target)
    {
        var cleaned = CleanMarkup(target).Trim();
        return string.IsNullOrWhiteSpace(cleaned)
            ? "Unknown"
            : System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(cleaned.ToLowerInvariant());
    }

