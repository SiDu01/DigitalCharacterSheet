    private IEnumerable<string> BuildInventoryWarnings()
    {
        if (AttunedItemCount >= 3)
        {
            yield return $"Attunement limit reached ({AttunedItemCount}/3).";
        }

        var equippedArmor = inventoryItems
            .Where(item => item.IsEquipped && item.ItemDefinition?.ArmorStats is not null && !IsShield(item.ItemDefinition))
            .ToList();
        if (equippedArmor.Count > 1)
        {
            yield return "Multiple armors equipped. Only one armor should be active.";
        }

        var equippedShields = inventoryItems
            .Where(item => item.IsEquipped && item.ItemDefinition is not null && IsShield(item.ItemDefinition))
            .ToList();
        if (equippedShields.Count > 1)
        {
            yield return "Multiple shields equipped. Only one shield should be active.";
        }
    }

