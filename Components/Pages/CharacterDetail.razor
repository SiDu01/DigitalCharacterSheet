    private static string BuildCombatActionKey(string actionTab, string source, string name)
    {
        return $"CombatAction|{actionTab}|{source}|{name}";
    }

    private static bool IsCombatActionKey(string key)
    {
        return key.StartsWith("CombatAction|", StringComparison.OrdinalIgnoreCase);
    }

    private IEnumerable<CombatActionOption> BuildCombatActions(string actionTab)
    {
        if (actionTab == "Actions")
        {
            yield return new CombatActionOption(
                BuildCombatActionKey(actionTab, "Common", "Attack"),
                "Attack",
                "Make one attack, or more if a feature grants Extra Attack.",
                "Use an equipped weapon, an unarmed strike, or another attack option available to the character.",
                ["Common"]);

            foreach (var weapon in EquippedWeapons)
            {
                yield return new CombatActionOption(
                    BuildCombatActionKey(actionTab, "Weapon", weapon.DisplayName),
                    weapon.DisplayName,
                    FormatWeaponAction(weapon),
                    BuildWeaponActionDescription(weapon),
                    BuildWeaponActionBadges(weapon).ToList());
            }
        }

        foreach (var feature in CombatFeatureActions.Where(feature => feature.ActionType == actionTab))
        {
            yield return new CombatActionOption(
                BuildCombatActionKey(actionTab, feature.SourceType, feature.Name),
                feature.Name,
                feature.Summary,
                feature.Description,
                [feature.SourceType, feature.Confidence]);
        }

        foreach (var spell in CombatPreparedSpells.Where(spell => SpellMatchesCombatActionTab(spell, actionTab)))
        {
            yield return new CombatActionOption(
                BuildCombatActionKey(actionTab, "Spell", $"{spell.Name}|{spell.Source}"),
                spell.Name,
                BuildSpellActionSummary(spell),
                string.IsNullOrWhiteSpace(spell.Description) ? BuildSpellActionSummary(spell) : CleanMarkup(spell.Description),
                BuildSpellActionBadges(spell).ToList());
        }

        if (actionTab == "Actions")
        {
            foreach (var action in BuildCommonActionOptions())
            {
                yield return action;
            }
        }
        else if (actionTab == "Reactions")
        {
            yield return new CombatActionOption(
                BuildCombatActionKey(actionTab, "Common", "Opportunity Attack"),
                "Opportunity Attack",
                "Make a melee attack when a hostile creature leaves your reach.",
                "Use your reaction to make one melee attack against the provoking creature.",
                ["Common"]);
            yield return new CombatActionOption(
                BuildCombatActionKey(actionTab, "Common", "Readied Action"),
                "Readied Action",
                "Use the reaction trigger from a previously readied action.",
                "When the trigger occurs before the start of your next turn, you can use your reaction to complete the readied action.",
                ["Common"]);
        }
        else if (!CombatFeatureActions.Any(feature => feature.ActionType == actionTab)
            && !CombatPreparedSpells.Any(spell => SpellMatchesCombatActionTab(spell, actionTab)))
        {
            yield return new CombatActionOption(
                BuildCombatActionKey(actionTab, "Info", "No detected options"),
                "No detected options",
                "No matching feature or spell actions detected yet.",
                "More options will appear here as features, spells, and item activations are mapped.",
                ["Info"]);
        }
    }

    private static IEnumerable<CombatActionOption> BuildCommonActionOptions()
    {
        yield return new CombatActionOption(BuildCombatActionKey("Actions", "Common", "Dodge"), "Dodge", "Attack rolls against you have disadvantage; DEX saves have advantage.", "Until the start of your next turn, attack rolls against you have disadvantage if you can see the attacker, and you make Dexterity saving throws with advantage.", ["Common"]);
        yield return new CombatActionOption(BuildCombatActionKey("Actions", "Common", "Dash"), "Dash", "Gain extra movement for the current turn.", "The increase equals your speed, after applying modifiers.", ["Common"]);
        yield return new CombatActionOption(BuildCombatActionKey("Actions", "Common", "Disengage"), "Disengage", "Your movement does not provoke opportunity attacks this turn.", "Useful when leaving enemy reach without spending a reaction from them.", ["Common"]);
        yield return new CombatActionOption(BuildCombatActionKey("Actions", "Common", "Help / Hide / Ready / Search"), "Help / Hide / Ready / Search", "Other common actions.", "Use the appropriate common action when the situation calls for support, stealth, delayed action, or investigation.", ["Common"]);
    }

    private static bool SpellMatchesCombatActionTab(Spell spell, string actionTab)
    {
        var unit = spell.CastingTimeUnit.ToLowerInvariant();
        var condition = spell.CastingTimeCondition.ToLowerInvariant();
        return actionTab switch
        {
            "BonusActions" => unit.Contains("bonus") || condition.Contains("bonus"),
            "Reactions" => unit.Contains("reaction") || condition.Contains("reaction"),
            _ => unit.Contains("action") && !unit.Contains("bonus") && !unit.Contains("reaction")
        };
    }

