    private async Task ToggleInventoryEquipped(CharacterInventoryItem item)
    {
        if (!item.IsCarried)
        {
            return;
        }

        var shouldEquip = !item.IsEquipped;
        if (shouldEquip && item.ItemDefinition is not null)
        {
            if (item.ItemDefinition.ArmorStats is not null && !IsShield(item.ItemDefinition))
            {
                foreach (var equippedArmor in inventoryItems.Where(inventoryItem =>
                    inventoryItem.Id != item.Id
                    && inventoryItem.IsEquipped
                    && inventoryItem.ItemDefinition?.ArmorStats is not null
                    && !IsShield(inventoryItem.ItemDefinition)))
                {
                    equippedArmor.IsEquipped = false;
                    await Database.UpdateCharacterInventoryItemAsync(equippedArmor);
                }
            }

            if (IsShield(item.ItemDefinition))
            {
                foreach (var equippedShield in inventoryItems.Where(inventoryItem =>
                    inventoryItem.Id != item.Id
                    && inventoryItem.IsEquipped
                    && inventoryItem.ItemDefinition is not null
                    && IsShield(inventoryItem.ItemDefinition)))
                {
                    equippedShield.IsEquipped = false;
                    await Database.UpdateCharacterInventoryItemAsync(equippedShield);
                }
            }
        }

        item.IsEquipped = shouldEquip;
        await Database.UpdateCharacterInventoryItemAsync(item);
        await LoadInventory();
    }

    private async Task ToggleInventoryCarried(CharacterInventoryItem item)
    {
