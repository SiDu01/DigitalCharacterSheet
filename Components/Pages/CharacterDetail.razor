    private async Task PersistCombatState()
    {
        if (character is null)
        {
            return;
        }

        character.MaxHitPoints = Math.Max(0, character.MaxHitPoints);
        character.CurrentHitPoints = Math.Clamp(character.CurrentHitPoints, 0, character.MaxHitPoints);
        character.TemporaryHitPoints = Math.Max(0, character.TemporaryHitPoints);
        character.ConditionsJson = System.Text.Json.JsonSerializer.Serialize(activeConditions.OrderBy(condition => condition).ToList());
        await Database.UpdateCharacterCombatStateAsync(character.Id, character.MaxHitPoints, character.CurrentHitPoints, character.TemporaryHitPoints, character.ConditionsJson);
    }

    private static IEnumerable<string> ReadConditionNames(string? conditionsJson)
    {
        if (string.IsNullOrWhiteSpace(conditionsJson))
        {
            yield break;
        }

        using var document = System.Text.Json.JsonDocument.Parse(conditionsJson);
        if (document.RootElement.ValueKind != System.Text.Json.JsonValueKind.Array)
        {
            yield break;
        }

        foreach (var condition in document.RootElement.EnumerateArray())
        {
            if (condition.ValueKind == System.Text.Json.JsonValueKind.String)
            {
                yield return condition.GetString() ?? "";
            }
        }
    }

