        || ClassFeatureGrantsHalfProficiency;
    private int ClassFeatureFightingStyleChoiceCount => CreationFeatures.Count(feature => feature.Name.Contains("Fighting Style", StringComparison.OrdinalIgnoreCase));
    private int ClassFeatureExpertiseChoiceCount => EffectiveClassFeatureMappedChoices
        .Where(choice => choice.ChoiceType == "SkillExpertise")
