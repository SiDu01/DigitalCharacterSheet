            []);
    }

    private static OptionDetail BuildClassDetail(ClassDefinition classDefinition, SubclassDefinition? subclassDefinition)
    {
        var featureGroups = new List<OptionDetailFeatureGroup>
        {
            new("Class Features", BuildFeatureLevelGroups(classDefinition.RawJson, "classFeatures").ToList())
        };

        if (subclassDefinition is not null)
        {
            var subclassFeatures = BuildFeatureLevelGroups(subclassDefinition.RawJson, "subclassFeatures").ToList();
            if (subclassFeatures.Count > 0)
            {
                featureGroups.Add(new($"{subclassDefinition.Name} Features", subclassFeatures));
            }
        }

        var progressionTables = BuildProgressionTables(classDefinition.RawJson).ToList();
        if (subclassDefinition is not null)
        {
            progressionTables.AddRange(BuildProgressionTables(subclassDefinition.RawJson));
        }

        return new OptionDetail(
            subclassDefinition is null ? "Class" : "Class / Subclass",
            subclassDefinition is null ? classDefinition.Name : $"{classDefinition.Name}: {subclassDefinition.Name}",
            classDefinition.Source,
            null,
            [
                new OptionDetailStat("Spellcasting", classDefinition.SpellcastingProgressionId is null ? "None" : "Has progression"),
                new OptionDetailStat("Source", classDefinition.Source),
                new OptionDetailStat("Subclass", subclassDefinition?.DisplayName ?? "None")
            ],
            [],
            featureGroups.Where(group => group.Levels.Count > 0).ToList(),
            progressionTables);
    }

    private static IEnumerable<OptionDetailFeatureLevel> BuildFeatureLevelGroups(string rawJson, string propertyName)
    {
        if (string.IsNullOrWhiteSpace(rawJson))
        {
            yield break;
        }

        using var document = JsonDocument.Parse(rawJson);
        if (!document.RootElement.TryGetProperty(propertyName, out var features) || features.ValueKind != JsonValueKind.Array)
        {
            yield break;
        }

        var details = BuildFeatureDetailLookup(document.RootElement);
        foreach (var group in features.EnumerateArray()
            .Select(feature => ParseFeatureReference(feature, details))
            .Where(feature => feature is not null)
            .Select(feature => feature!)
            .GroupBy(feature => feature.Level)
            .OrderBy(group => group.Key))
        {
            yield return new OptionDetailFeatureLevel(
                group.Key,
                group
                    .GroupBy(feature => feature.Key, StringComparer.OrdinalIgnoreCase)
                    .Select(group => group.First())
                    .OrderBy(feature => feature.Name)
                    .ToList());
        }
    }

    private static Dictionary<string, IReadOnlyList<string>> BuildFeatureDetailLookup(JsonElement root)
    {
        var details = new Dictionary<string, IReadOnlyList<string>>(StringComparer.OrdinalIgnoreCase);
        if (!root.TryGetProperty("_featureDetails", out var featureDetails) || featureDetails.ValueKind != JsonValueKind.Array)
        {
            return details;
        }

        foreach (var featureDetail in featureDetails.EnumerateArray())
        {
            var name = ReadJsonString(featureDetail, "name");
            if (string.IsNullOrWhiteSpace(name) || !featureDetail.TryGetProperty("level", out var levelElement))
            {
                continue;
            }

            var level = levelElement.ValueKind == JsonValueKind.Number && levelElement.TryGetInt32(out var parsedLevel)
                ? parsedLevel
                : 0;
            if (level is < 1 or > 20)
            {
                continue;
            }

            var paragraphs = featureDetail.TryGetProperty("entries", out var entries)
                ? ExtractParagraphs(entries).ToList()
                : [];
            details[BuildFeatureKey(name, level)] = paragraphs;
        }

        return details;
    }

    private static OptionDetailFeature? ParseFeatureReference(JsonElement element, IReadOnlyDictionary<string, IReadOnlyList<string>> details)
    {
        var reference = element.ValueKind switch
        {
            JsonValueKind.String => element.GetString(),
            JsonValueKind.Object when element.TryGetProperty("classFeature", out var classFeature) => classFeature.GetString(),
            JsonValueKind.Object when element.TryGetProperty("subclassFeature", out var subclassFeature) => subclassFeature.GetString(),
            _ => null
        };

        if (string.IsNullOrWhiteSpace(reference))
        {
            return null;
        }

        var parts = reference.Split('|', StringSplitOptions.None);
        var level = parts
            .Select(part => int.TryParse(part, out var parsed) ? parsed : 0)
            .LastOrDefault(parsed => parsed is >= 1 and <= 20);

        if (level == 0)
        {
            return null;
        }

        var name = CleanMarkup(parts[0]);
        var key = BuildFeatureKey(name, level);
        return new OptionDetailFeature(name, level, key, details.GetValueOrDefault(key) ?? []);
    }

    private static string BuildFeatureKey(string name, int level)
    {
        return $"{CleanMarkup(name).Trim()}|{level}";
    }

    private static IEnumerable<OptionDetailProgressionTable> BuildProgressionTables(string rawJson)
    {
        if (string.IsNullOrWhiteSpace(rawJson))
        {
            yield break;
        }

        using var document = JsonDocument.Parse(rawJson);
        foreach (var propertyName in new[] { "classTableGroups", "subclassTableGroups" })
        {
            if (!document.RootElement.TryGetProperty(propertyName, out var tableGroups) || tableGroups.ValueKind != JsonValueKind.Array)
            {
                continue;
            }

            foreach (var tableGroup in tableGroups.EnumerateArray())
            {
                var table = BuildProgressionTable(tableGroup);
                if (table is not null)
                {
                    yield return table;
                }
            }
        }
    }

    private static OptionDetailProgressionTable? BuildProgressionTable(JsonElement tableGroup)
    {
        var rowProperty = tableGroup.TryGetProperty("rowsSpellProgression", out var spellRows)
            ? spellRows
            : tableGroup.TryGetProperty("rows", out var normalRows)
                ? normalRows
                : default;

        if (rowProperty.ValueKind != JsonValueKind.Array)
        {
            return null;
        }

        var labels = ReadColumnLabels(tableGroup, rowProperty).ToList();
        var containsSpellData = tableGroup.TryGetProperty("rowsSpellProgression", out _)
            || labels.Any(label => label.Contains("spell", StringComparison.OrdinalIgnoreCase)
                || label.Contains("cantrip", StringComparison.OrdinalIgnoreCase)
                || label.Contains("slot", StringComparison.OrdinalIgnoreCase)
                || label.Contains("prepared", StringComparison.OrdinalIgnoreCase));

        if (!containsSpellData)
        {
            return null;
        }

        var rows = new List<OptionDetailProgressionRow>();
        var level = 1;
        foreach (var row in rowProperty.EnumerateArray())
        {
            if (row.ValueKind != JsonValueKind.Array)
            {
                level++;
                continue;
            }

            var values = new List<string> { level.ToString() };
            values.AddRange(row.EnumerateArray().Select(FormatTableCell));
            rows.Add(new OptionDetailProgressionRow(values));
            level++;
        }

        if (rows.Count == 0)
        {
            return null;
        }

        var title = ReadJsonString(tableGroup, "title");
        return new OptionDetailProgressionTable(
            string.IsNullOrWhiteSpace(title) ? "Spell Progression" : CleanMarkup(title),
            ["Level", .. labels],
            rows);
    }

    private static IEnumerable<string> ReadColumnLabels(JsonElement tableGroup, JsonElement rows)
    {
        if (tableGroup.TryGetProperty("colLabels", out var labels) && labels.ValueKind == JsonValueKind.Array)
        {
            foreach (var label in labels.EnumerateArray())
            {
                yield return CleanMarkup(FormatTableCell(label));
            }

            yield break;
        }

        var width = rows.EnumerateArray().FirstOrDefault(row => row.ValueKind == JsonValueKind.Array).GetArrayLength();
        for (var index = 1; index <= width; index++)
        {
            yield return FormatOrdinal(index);
        }
    }

    private static string FormatTableCell(JsonElement element)
    {
        return element.ValueKind switch
        {
            JsonValueKind.String => element.GetString() ?? "",
            JsonValueKind.Number => element.GetRawText(),
            JsonValueKind.True => "Yes",
            JsonValueKind.False => "No",
            JsonValueKind.Null => "-",
            JsonValueKind.Array => string.Join(" / ", element.EnumerateArray().Select(FormatTableCell)),
            JsonValueKind.Object when element.TryGetProperty("type", out var type) && type.GetString() == "bonus" => $"+{ReadJsonString(element, "value")}",
            _ => CleanMarkup(element.GetRawText())
        };
    }

    private static string FormatOrdinal(int value)
    {
        var suffix = (value % 100) is 11 or 12 or 13
            ? "th"
            : (value % 10) switch
            {
                1 => "st",
                2 => "nd",
                3 => "rd",
                _ => "th"
            };

        return $"{value}{suffix}";
    }

    private static IEnumerable<OptionDetailSection> BuildSections(string rawJson)
    {
        if (string.IsNullOrWhiteSpace(rawJson))
        {
            yield break;
        }

        using var document = JsonDocument.Parse(rawJson);
        if (!document.RootElement.TryGetProperty("entries", out var entries) || entries.ValueKind != JsonValueKind.Array)
        {
            yield break;
        }

        foreach (var entry in entries.EnumerateArray())
        {
            var title = ReadJsonString(entry, "name");
            var paragraphs = ExtractParagraphs(entry).ToList();
            if (paragraphs.Count == 0)
            {
                continue;
            }

            yield return new OptionDetailSection(string.IsNullOrWhiteSpace(title) ? "Details" : title, paragraphs);
        }
    }

    private static IEnumerable<string> ExtractParagraphs(JsonElement element)
    {
        if (element.ValueKind == JsonValueKind.String)
        {
            yield return element.GetString() ?? "";
            yield break;
        }

        if (element.ValueKind == JsonValueKind.Object)
        {
            if (element.TryGetProperty("entry", out var entry))
            {
                foreach (var value in ExtractParagraphs(entry))
                {
                    yield return value;
                }
            }

            if (element.TryGetProperty("entries", out var entries))
            {
                foreach (var value in ExtractParagraphs(entries))
                {
                    yield return value;
                }
            }

            if (element.TryGetProperty("items", out var items))
            {
                foreach (var value in ExtractParagraphs(items))
                {
                    yield return value;
                }
            }

            yield break;
        }

        if (element.ValueKind != JsonValueKind.Array)
        {
            yield break;
        }

        foreach (var item in element.EnumerateArray())
        {
            if (item.ValueKind == JsonValueKind.Object && item.TryGetProperty("name", out var name))
            {
                var text = string.Join(" ", ExtractParagraphs(item));
                if (!string.IsNullOrWhiteSpace(text))
                {
                    yield return $"{name.GetString()}: {text}";
                }
                continue;
            }

            foreach (var value in ExtractParagraphs(item))
            {
                yield return value;
            }
        }
    }

    private static IEnumerable<string> GetStringArray(string? rawJson)
    {
        if (string.IsNullOrWhiteSpace(rawJson))
        {
            yield break;
        }

        using var document = JsonDocument.Parse(rawJson);
        if (document.RootElement.ValueKind != JsonValueKind.Array)
        {
            yield break;
        }

        foreach (var item in document.RootElement.EnumerateArray())
        {
            if (item.ValueKind == JsonValueKind.String)
            {
                yield return item.GetString() ?? "";
            }
        }
    }

    private static string FormatSizeList(IEnumerable<string> sizes)
    {
        var formatted = sizes.Select(FormatSize).ToList();
        return formatted.Count == 0 ? "Unknown" : string.Join(" / ", formatted);
    }

    private static string FormatSize(string size)
    {
        return size switch
        {
            "T" => "Tiny",
            "S" => "Small",
            "M" => "Medium",
            "L" => "Large",
            "H" => "Huge",
            "G" => "Gargantuan",
            _ => size
        };
    }

    private static string FormatJsonSummary(string rawJson)
    {
        if (string.IsNullOrWhiteSpace(rawJson))
        {
            return "None";
        }

        return CleanMarkup(rawJson)
            .Replace("{", "")
            .Replace("}", "")
            .Replace("[", "")
            .Replace("]", "")
            .Replace("\"", "")
            .Replace(":", ": ")
            .Replace(",", ", ");
    }

    private static string ReadJsonString(JsonElement element, string propertyName)
    {
        return element.ValueKind == JsonValueKind.Object
            && element.TryGetProperty(propertyName, out var property)
            && property.ValueKind == JsonValueKind.String
            ? property.GetString() ?? ""
            : "";
    }

    private static string CleanMarkup(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "";
        }

        var cleaned = value.Replace("{@dc ", "DC ");
        cleaned = System.Text.RegularExpressions.Regex.Replace(
            cleaned,
            @"\{@[a-zA-Z]+ ([^|}]+)(?:\|[^}]*)?\}",
            "$1");

        return cleaned
            .Replace("|XPHB", "")
            .Replace("|PHB", "")
            .Replace("}", "")
            .Trim();
    }

    private sealed record OptionDetail(
        string Kind,
        string Name,
        string Source,
        int? Page,
        IReadOnlyList<OptionDetailStat> Stats,
        IReadOnlyList<OptionDetailSection> Sections,
        IReadOnlyList<OptionDetailFeatureGroup> FeatureGroups,
        IReadOnlyList<OptionDetailProgressionTable> ProgressionTables);
    private sealed record OptionDetailStat(string Label, string Value);
    private sealed record OptionDetailSection(string Title, IReadOnlyList<string> Paragraphs);
    private sealed record OptionDetailFeature(string Name, int Level, string Key, IReadOnlyList<string> Paragraphs);
    private sealed record OptionDetailFeatureLevel(int Level, IReadOnlyList<OptionDetailFeature> Features);
    private sealed record OptionDetailFeatureGroup(string Title, IReadOnlyList<OptionDetailFeatureLevel> Levels);
    private sealed record OptionDetailProgressionTable(string Title, IReadOnlyList<string> Columns, IReadOnlyList<OptionDetailProgressionRow> Rows);
    private sealed record OptionDetailProgressionRow(IReadOnlyList<string> Values);
}
