    private IEnumerable<FeatChoiceSource> BuildFeatChoiceSources()
    {
        var occurrenceByFeatId = new Dictionary<int, int>();
        foreach (var characterFeat in BuildStoredFeats())
        {
            var feat = featDefinitions.FirstOrDefault(definition => definition.Id == characterFeat.FeatDefinitionId);
            if (feat is null)
            {
                continue;
            }

            var occurrence = occurrenceByFeatId.GetValueOrDefault(feat.Id);
            occurrenceByFeatId[feat.Id] = occurrence + 1;
            yield return new FeatChoiceSource(feat, occurrence == 0 ? $"Feat:{feat.Id}" : $"Feat:{feat.Id}:repeat:{occurrence}");
        }
    }

    private void PruneDefenseChoices()
    {
        var validKeys = AllDefenseChoiceRequirements.Select(requirement => requirement.Key).ToHashSet(StringComparer.OrdinalIgnoreCase);
        foreach (var key in selectedDefenseChoices.Keys.Where(key => !validKeys.Contains(key)).ToList())
        {
            selectedDefenseChoices.Remove(key);
        }
    }

    private void PruneAbilityChoices()
    {
        var validKeys = AllAbilityChoiceRequirements
            .Select(requirement => requirement.Key)
            .Concat(AllAbilityChoiceRequirements.Select(requirement => CharacterAbilityChoiceService.BuildModeMarkerKey(requirement.ModeGroupKey)))
            .Concat(AllAbilityChoiceRequirements.Select(requirement => CharacterAbilityChoiceService.BuildUnrestrictedMarkerKey(requirement.ModeGroupKey)))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        foreach (var key in selectedAbilityChoices.Keys.Where(key => !validKeys.Contains(key)).ToList())
        {
            selectedAbilityChoices.Remove(key);
        }
    }

    private void PruneClassFeatureChoices()
    {
        var featChoiceKeys = ClassFeatureFeatChoiceRows.Select(row => row.Key).ToHashSet(StringComparer.OrdinalIgnoreCase);
        foreach (var key in selectedClassFeatureFeatIds.Keys.Where(key => !featChoiceKeys.Contains(key)).ToList())
        {
            selectedClassFeatureFeatIds.Remove(key);
        }

        TrimChoiceSet(selectedClassFeatureFightingStyles, ClassFeatureFightingStyleChoiceCount);
        TrimChoiceSet(selectedClassFeatureExpertiseSkills, ClassFeatureExpertiseChoiceCount);
        TrimChoiceSet(selectedClassFeatureSkillProficiencies, ClassFeatureSkillProficiencyChoiceCount);
        TrimChoiceSet(selectedClassFeatureToolProficiencies, ClassFeatureToolProficiencyChoiceCount);
        TrimChoiceSet(selectedClassFeatureLanguageProficiencies, ClassFeatureLanguageProficiencyChoiceCount);
    }

    private static void TrimChoiceSet(HashSet<string> selected, int limit)
    {
        if (selected.Count <= limit)
        {
            return;
        }

        foreach (var value in selected.Skip(limit).ToList())
        {
            selected.Remove(value);
        }
    }

