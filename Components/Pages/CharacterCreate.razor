        && (ClassFeatureExpertiseChoiceCount == 0 || selectedClassFeatureExpertiseSkills.Count == ClassFeatureExpertiseChoiceCount)
        && (ClassFeatureSkillProficiencyChoiceCount == 0 || selectedClassFeatureSkillProficiencies.Count == ClassFeatureSkillProficiencyChoiceCount)
        && (ClassFeatureToolProficiencyChoiceCount == 0 || selectedClassFeatureToolProficiencies.Count == ClassFeatureToolProficiencyChoiceCount)
