    private async Task ApplyOptionEffects()
    {
        var effects = await SpellDatabase.GetCharacterOptionEffectsAsync(BuildDraftCharacter());
        strength = 10 + effects.AbilityBonuses.GetValueOrDefault("str");
        dexterity = 10 + effects.AbilityBonuses.GetValueOrDefault("dex");
        constitution = 10 + effects.AbilityBonuses.GetValueOrDefault("con");
        intelligence = 10 + effects.AbilityBonuses.GetValueOrDefault("int");
        wisdom = 10 + effects.AbilityBonuses.GetValueOrDefault("wis");
        charisma = 10 + effects.AbilityBonuses.GetValueOrDefault("cha");

        foreach (var savingThrow in savingThrows)
        {
            savingThrow.IsProficient = effects.SavingThrowProficiencies.Contains(savingThrow.AbilityCode);
        }

        optionEffectMessages = effects.DeferredChoices.Count == 0
            ? []
            : [$"Manual choices still needed: {string.Join(", ", effects.DeferredChoices.Distinct())}"];
        optionChoiceHints = effects.ChoiceHints;
        automaticSkillProficiencies = effects.SkillProficiencies.ToHashSet(StringComparer.OrdinalIgnoreCase);
        automaticToolProficiencies = effects.ToolProficiencies.ToHashSet(StringComparer.OrdinalIgnoreCase);
        automaticLanguageProficiencies = effects.LanguageProficiencies.ToHashSet(StringComparer.OrdinalIgnoreCase);
        selectedManualSkillChoices.RemoveWhere(skillName => automaticSkillProficiencies.Contains(skillName));
        selectedManualToolChoices.RemoveWhere(toolName => automaticToolProficiencies.Contains(toolName));
        selectedManualLanguageChoices.RemoveWhere(languageName => automaticLanguageProficiencies.Contains(languageName));
        if (selectedManualSkillChoices.Count > SkillChoiceLimit)
        {
            selectedManualSkillChoices = selectedManualSkillChoices.Take(SkillChoiceLimit).ToHashSet(StringComparer.OrdinalIgnoreCase);
        }
        if (selectedManualLanguageChoices.Count > LanguageChoiceLimit)
        {
            selectedManualLanguageChoices = selectedManualLanguageChoices.Take(LanguageChoiceLimit).ToHashSet(StringComparer.OrdinalIgnoreCase);
        }
        foreach (var skill in skills)
        {
            skill.IsProficient = automaticSkillProficiencies.Contains(skill.Name)
                || selectedManualSkillChoices.Contains(skill.Name);
        }
        foreach (var tool in toolProficiencies)
        {
            tool.IsProficient = automaticToolProficiencies.Contains(tool.Name)
                || selectedManualToolChoices.Contains(tool.Name);
        }
        foreach (var language in languageProficiencies)
        {
            language.IsProficient = automaticLanguageProficiencies.Contains(language.Name)
                || selectedManualLanguageChoices.Contains(language.Name);
        }
    }

    private IReadOnlyList<CharacterOptionChoice> ChoiceHintsFor(string category)
    {
        return optionChoiceHints
            .Where(choice => string.Equals(choice.Category, category, StringComparison.OrdinalIgnoreCase)
                || (string.Equals(choice.Category, "SkillTools", StringComparison.OrdinalIgnoreCase)
                    && (string.Equals(category, "Skills", StringComparison.OrdinalIgnoreCase)
                        || string.Equals(category, "Tools", StringComparison.OrdinalIgnoreCase))))
            .GroupBy(choice => $"{choice.Source}|{choice.Description}", StringComparer.OrdinalIgnoreCase)
            .Select(group => group.First())
            .ToList();
    }

    private bool IsSkillChoiceDisabled(CharacterSkill skill)
    {
        if (automaticSkillProficiencies.Contains(skill.Name))
        {
            return true;
        }

        return !skill.IsProficient && SkillChoiceLimit > 0 && ManualSkillChoiceCount >= SkillChoiceLimit;
    }

    private bool IsToolChoiceDisabled(CharacterToolProficiency tool)
    {
        if (automaticToolProficiencies.Contains(tool.Name))
        {
            return true;
        }

        return !tool.IsProficient && ToolChoiceLimit > 0 && ManualToolChoiceCount >= ToolChoiceLimit;
    }

    private bool IsLanguageChoiceDisabled(CharacterLanguageProficiency language)
    {
        if (automaticLanguageProficiencies.Contains(language.Name))
        {
            return true;
        }

        return !language.IsProficient && LanguageChoiceLimit > 0 && ManualLanguageChoiceCount >= LanguageChoiceLimit;
    }

    private void ToggleSkillProficiency(CharacterSkill skill, bool isChecked)
    {
        if (automaticSkillProficiencies.Contains(skill.Name))
        {
            skill.IsProficient = true;
            return;
        }

        if (isChecked)
        {
            if (SkillChoiceLimit == 0 || ManualSkillChoiceCount < SkillChoiceLimit)
            {
                selectedManualSkillChoices.Add(skill.Name);
                skill.IsProficient = true;
            }

            return;
        }

        selectedManualSkillChoices.Remove(skill.Name);
        skill.IsProficient = false;
    }

    private void ToggleToolProficiency(CharacterToolProficiency tool, bool isChecked)
    {
        if (automaticToolProficiencies.Contains(tool.Name))
        {
            tool.IsProficient = true;
            return;
        }

        if (isChecked)
        {
            if (ToolChoiceLimit == 0 || ManualToolChoiceCount < ToolChoiceLimit)
            {
                selectedManualToolChoices.Add(tool.Name);
                tool.IsProficient = true;
            }

            return;
        }

        selectedManualToolChoices.Remove(tool.Name);
        tool.IsProficient = false;
    }

    private void ToggleLanguageProficiency(CharacterLanguageProficiency language, bool isChecked)
    {
        if (automaticLanguageProficiencies.Contains(language.Name))
        {
            language.IsProficient = true;
            return;
        }

        if (isChecked)
        {
            if (LanguageChoiceLimit == 0 || ManualLanguageChoiceCount < LanguageChoiceLimit)
            {
                selectedManualLanguageChoices.Add(language.Name);
                language.IsProficient = true;
            }

            return;
        }

        selectedManualLanguageChoices.Remove(language.Name);
        language.IsProficient = false;
    }

    private Character BuildDraftCharacter()
    {
        var raceDefinition = SelectedRace;
        var backgroundDefinition = SelectedBackground;
        return new Character
        {
            Name = newName,
            RaceDefinitionId = raceDefinition?.Id,
            SubraceDefinitionId = SelectedSubrace?.Id,
            RaceName = raceDefinition?.Name ?? "",
            RaceChoicesJson = BuildRaceChoicesJson(),
            BackgroundDefinitionId = backgroundDefinition?.Id,
            BackgroundName = backgroundDefinition?.Name ?? "",
            BackgroundChoicesJson = "{}",
            FeatChoicesJson = "{}",
            ClassName = string.Join(" / ", newClasses.Select(characterClass => characterClass.ClassName).Distinct()),
            PrimaryClassDefinitionId = primaryClassDefinitionId,
            Level = newClasses.Count == 0 ? null : newClasses.Sum(characterClass => characterClass.Level),
            Strength = strength,
            Dexterity = dexterity,
            Constitution = constitution,
            Intelligence = intelligence,
            Wisdom = wisdom,
            Charisma = charisma,
            Classes = newClasses.ToList(),
            Feats = newFeats.ToList(),
            SavingThrows = savingThrows.ToList(),
            Skills = skills.ToList(),
            ToolProficiencies = toolProficiencies.ToList(),
            LanguageProficiencies = languageProficiencies.ToList()
        };
    }

    private string BuildRaceChoicesJson()
    {
        var choices = new Dictionary<string, string>();
        if (!string.IsNullOrWhiteSpace(selectedRaceSize))
        {
            choices["size"] = selectedRaceSize;
        }

        return choices.Count == 0 ? "{}" : JsonSerializer.Serialize(choices);
    }

    private static OptionDetail BuildRaceDetail(RaceDefinition race, SubraceDefinition? subrace)
    {
        var sections = BuildSections(race.RawJson).ToList();
        if (subrace is not null)
        {
            sections.InsertRange(0, BuildSections(subrace.RawJson).Select(section => new OptionDetailSection($"Version: {section.Title}", section.Paragraphs)));
        }

        return new OptionDetail(
            "Race",
            race.Name,
            race.Source,
            race.Page,
            [
                new OptionDetailStat("Size", FormatSizeList(GetStringArray(race.SizeJson))),
                new OptionDetailStat("Speed", FormatJsonSummary(race.SpeedJson)),
                new OptionDetailStat("Ability", FormatJsonSummary(race.AbilityJson))
            ],
            sections,
            [],
            []);
    }

    private static OptionDetail BuildBackgroundDetail(BackgroundDefinition background)
    {
        return new OptionDetail(
            "Background",
            background.Name,
            background.Source,
            background.Page,
            [
                new OptionDetailStat("Ability", FormatJsonSummary(background.AbilityJson)),
                new OptionDetailStat("Skills", FormatJsonSummary(background.SkillProficienciesJson)),
                new OptionDetailStat("Tools", FormatJsonSummary(background.ToolProficienciesJson))
            ],
            BuildSections(background.RawJson).ToList(),
            [],
            []);
    }

    private static OptionDetail BuildFeatDetail(FeatDefinition feat)
    {
        return new OptionDetail(
            "Feat",
            feat.Name,
            feat.Source,
            feat.Page,
            [
                new OptionDetailStat("Category", string.IsNullOrWhiteSpace(feat.Category) ? "None" : feat.Category),
                new OptionDetailStat("Prerequisite", FormatJsonSummary(feat.PrerequisiteJson)),
                new OptionDetailStat("Spells", string.IsNullOrWhiteSpace(feat.AdditionalSpellsJson) ? "None" : "Has spell choices")
            ],
            BuildSections(feat.RawJson).ToList(),
