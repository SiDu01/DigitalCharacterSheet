    private RaceDefinition? SelectedRace => selectedRaceDefinitionId is null ? null : raceDefinitions.FirstOrDefault(definition => definition.Id == selectedRaceDefinitionId.Value);
    private SubraceDefinition? SelectedSubrace => selectedSubraceDefinitionId is null ? null : subraceDefinitions.FirstOrDefault(definition => definition.Id == selectedSubraceDefinitionId.Value);
    private BackgroundDefinition? SelectedBackground => selectedBackgroundDefinitionId is null ? null : backgroundDefinitions.FirstOrDefault(definition => definition.Id == selectedBackgroundDefinitionId.Value);
    private FeatDefinition? SelectedFeat => selectedFeatDefinitionId is null ? null : featDefinitions.FirstOrDefault(definition => definition.Id == selectedFeatDefinitionId.Value);
    private IReadOnlyList<FeatGroup> FilteredFeatGroups => (showOnlyOriginFeats
            ? featDefinitions.Where(IsOriginFeat)
            : featDefinitions)
        .GroupBy(definition => definition.Name, StringComparer.OrdinalIgnoreCase)
        .Select(group => new FeatGroup(group))
        .OrderBy(group => group.Name)
        .ToList();
    private IReadOnlyList<string> GrantedFeatSummaries => BuildGrantedFeatSummaries().ToList();
    private ClassDefinition? SelectedClass => selectedClassDefinitionId is null ? null : classDefinitions.FirstOrDefault(definition => definition.Id == selectedClassDefinitionId.Value);
    private SubclassDefinition? SelectedSubclass => selectedSubclassDefinitionId is null ? null : subclassDefinitions.FirstOrDefault(definition => definition.Id == selectedSubclassDefinitionId.Value);
    private List<string> RaceSizeOptions => GetStringArray(SelectedRace?.SizeJson).ToList();
    private IReadOnlyList<CharacterDefenseChoiceRequirement> RaceDefenseChoiceRequirements => BuildRaceDefenseChoiceRequirements().ToList();
    private IReadOnlyList<CharacterDefenseChoiceRequirement> BackgroundDefenseChoiceRequirements => BuildBackgroundDefenseChoiceRequirements().ToList();
    private IReadOnlyList<CharacterDefenseChoiceRequirement> FeatDefenseChoiceRequirements => BuildFeatDefenseChoiceRequirements().ToList();
    private IReadOnlyList<CharacterAbilityChoiceRequirement> RaceAbilityChoiceRequirements => BuildRaceAbilityChoiceRequirements().ToList();
    private IReadOnlyList<CharacterAbilityChoiceRequirement> BackgroundAbilityChoiceRequirements => BuildBackgroundAbilityChoiceRequirements().ToList();
    private IReadOnlyList<CharacterAbilityChoiceRequirement> FeatAbilityChoiceRequirements => BuildFeatAbilityChoiceRequirements().ToList();
    private IReadOnlyList<CreationFeatureLevel> CreationFeatureLevels => BuildCreationFeatureLevels().ToList();
    private IReadOnlyList<CreationFeature> CreationFeatures => CreationFeatureLevels.SelectMany(level => level.Features).ToList();
    private IReadOnlyList<ClassFeatureFeatChoiceRow> ClassFeatureFeatChoiceRows => CreationFeatures
        .Where(feature => IsFeatChoiceFeature(feature.Name))
        .Select(feature => new ClassFeatureFeatChoiceRow(feature.Key, feature.ClassDefinitionId, feature.ClassName, feature.Level, feature.Name))
        .ToList();
    private IReadOnlyList<MappedClassFeatureChoiceRow> MappedClassFeatureChoiceRows => CreationFeatures
        .SelectMany(feature => DescriptionRuleMapper.MapFeature(feature.Name, feature.Paragraphs).Choices
            .Select((choice, choiceIndex) => new MappedClassFeatureChoiceRow($"{feature.Key}:choice:{choiceIndex}", feature.ClassDefinitionId, feature.ClassName, feature.Level, feature.Name, choice)))
        .ToList();
    private IReadOnlyList<MappedRuleChoice> EffectiveClassFeatureMappedChoices => MappedClassFeatureChoiceRows
        .Select(row => row.Choice)
        .Where(choice => choice.Count > 0)
        .ToList();
    private IReadOnlyList<FeatDefinition> SelectedClassFeatureFeatDefinitions => selectedClassFeatureFeatIds
        .OrderBy(pair => pair.Key, StringComparer.OrdinalIgnoreCase)
        .Select(pair => pair.Value)
        .Select(id => featDefinitions.FirstOrDefault(definition => definition.Id == id))
        .Where(definition => definition is not null)
        .Select(definition => definition!)
        .ToList();
    private IReadOnlyList<CharacterAbilityChoiceRequirement> ClassFeatureAbilityChoiceRequirements => FeatAbilityChoiceRequirements;
    private bool HasClassFeatureChoices => ClassFeatureFeatChoiceRows.Count > 0
