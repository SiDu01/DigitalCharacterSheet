@page "/characters/new"
@using System.Text.Json
@inject AppDatabase Database
@inject NavigationManager Navigation

<PageTitle>Create Character</PageTitle>

<section class="character-page character-create-page">
    <button class="back-button" title="Back" aria-label="Back" @onclick="OpenCharacters">‹</button>

    <header class="page-header creation-header">
        <div class="creation-title-area">
            <p class="eyebrow">Character Creation</p>
            <div class="creation-title-row">
                <h1>New Character</h1>
                <nav class="creation-step-badges" aria-label="Character creation steps">
                    @foreach (var step in CreationSteps)
                    {
                        <button type="button"
                                class="creation-step-badge @(currentStep == step.Key ? "active" : "")"
                                title="@step.Label"
                                @onclick="() => SetStep(step.Key)">
                            <span>@step.Number</span>
                            <strong>@step.Label</strong>
                        </button>
                    }
                </nav>
            </div>
        </div>
        <div class="creation-header-actions">
            <button type="button" class="primary-action" disabled="@isCreating" @onclick="CreateCharacter">Create</button>
        </div>
    </header>

    <section class="creator-workspace">
        <section class="creator-step-panel">
            <section class="creator-step-screen @(IsStep("Identity") ? "" : "hidden")">
                <div class="creator-step-heading">
                    <p class="eyebrow">Identity</p>
                    <div class="creator-step-controls">
                        <button type="button" class="text-button no-margin" disabled="@IsFirstStep" @onclick="PreviousStep">Previous</button>
                        <button type="button" class="text-button no-margin" disabled="@IsLastStep" @onclick="NextStep">Next</button>
                    </div>
                </div>
                <input placeholder="Name" @bind="newName" @bind:event="oninput" />
            </section>

            <section class="creator-step-screen creator-ancestry-step @(IsStep("Ancestry") ? "" : "hidden")">
                <div class="creator-step-heading">
                    <p class="eyebrow">Ancestry</p>
                    <div class="creator-step-controls">
                        <button type="button" class="text-button no-margin" disabled="@IsFirstStep" @onclick="PreviousStep">Previous</button>
                        <button type="button" class="text-button no-margin" disabled="@IsLastStep" @onclick="NextStep">Next</button>
                    </div>
                </div>
                <section class="creator-option-list" aria-label="Available ancestry options">
                    @foreach (var raceGroup in raceGroups)
                    {
                        <button type="button"
                                class="creator-option-row @(string.Equals(selectedRaceName, raceGroup.Name, StringComparison.OrdinalIgnoreCase) ? "selected" : "")"
                                @onclick="async () => await SelectRaceGroup(raceGroup)">
                            <span>@raceGroup.Name</span>
                            <small>@string.Join(" / ", raceGroup.Versions.Select(version => version.Source).Distinct())</small>
                        </button>
                    }
                </section>

            </section>

            <section class="creator-step-screen creator-list-step @(IsStep("Background") ? "" : "hidden")">
                <div class="creator-step-heading">
                    <p class="eyebrow">Background</p>
                    <div class="creator-step-controls">
                        <button type="button" class="text-button no-margin" disabled="@IsFirstStep" @onclick="PreviousStep">Previous</button>
                        <button type="button" class="text-button no-margin" disabled="@IsLastStep" @onclick="NextStep">Next</button>
                    </div>
                </div>
                <section class="creator-option-list" aria-label="Available background options">
                    @foreach (var backgroundGroup in backgroundGroups)
                    {
                        <button type="button"
                                class="creator-option-row @(string.Equals(selectedBackgroundName, backgroundGroup.Name, StringComparison.OrdinalIgnoreCase) ? "selected" : "")"
                                @onclick="async () => await SelectBackgroundGroup(backgroundGroup)">
                            <span>@backgroundGroup.Name</span>
                            <small>@string.Join(" / ", backgroundGroup.Versions.Select(version => version.Source).Distinct())</small>
                        </button>
                    }
                </section>

            </section>

            <section class="creator-step-screen @(IsStep("Classes") ? "" : "hidden")">
                <div class="creator-step-heading">
                    <p class="eyebrow">Classes</p>
                    <div class="creator-step-controls">
                        <button type="button" class="text-button no-margin" disabled="@IsFirstStep" @onclick="PreviousStep">Previous</button>
                        <button type="button" class="text-button no-margin" disabled="@IsLastStep" @onclick="NextStep">Next</button>
                    </div>
                </div>
                <div class="class-picker">
                    <select @bind="selectedClassName" @bind:after="SelectClassGroup">
                        <option value="0">Select class</option>
                        @foreach (var classGroup in classGroups)
                        {
                            <option value="@classGroup.Name">@classGroup.Name</option>
                        }
                    </select>
                    <input placeholder="Level" type="number" min="1" max="20" @bind="selectedClassLevel" @bind:after="RecomputeOptionEffectsAsync" />
                    <button type="button" class="text-button" @onclick="AddClass">Add Class</button>
                </div>

                @if (selectedClassGroup is not null)
                {
                    <div class="class-source-row">
                        <select @bind="selectedSubclassDefinitionId" @bind:after="SelectSubclass">
                            <option value="">No subclass</option>
                            @foreach (var subclassDefinition in subclassDefinitions)
                            {
                                <option value="@subclassDefinition.Id">@subclassDefinition.DisplayName</option>
                            }
                        </select>
                    </div>
                }

                @if (newClasses.Count > 0)
                {
                    <label class="stacked-field">
                        <span>First class</span>
                        <select @bind="primaryClassDefinitionId" @bind:after="RecomputeOptionEffectsAsync">
                            <option value="">Select first class</option>
                            @foreach (var characterClass in newClasses)
                            {
                                <option value="@characterClass.ClassDefinitionId">@characterClass.DisplayName</option>
                            }
                        </select>
                    </label>

                    <section class="selected-class-list">
                        @foreach (var characterClass in newClasses)
                        {
                            <div class="selected-class-row">
                                <button type="button" class="text-link-button" @onclick="async () => await ShowClassDetails(characterClass)">@characterClass.DisplayName</button>
                                <button type="button" class="icon-button" title="Remove class" @onclick="() => RemoveClass(characterClass)">-</button>
                            </div>
                        }
                    </section>
                }

                @if (optionEffectMessages.Count > 0)
                {
                    <p class="muted compact-hint">@string.Join("; ", optionEffectMessages)</p>
                }

                @if (ClassFeatureFightingStyleChoiceCount > 0)
                {
                    <section class="level-up-choice creator-class-feature-choice">
                        <p class="eyebrow">Class Feature Choices</p>
                        <p class="muted compact-hint">Select @ClassFeatureFightingStyleChoiceCount fighting style(s).</p>
                        <div class="level-up-choice-grid">
                            @foreach (var fightingStyle in FightingStyleOptions)
                            {
                                <label class="toggle">
                                    <input type="checkbox"
                                           checked="@selectedClassFeatureFightingStyles.Contains(fightingStyle)"
                                           disabled="@(!selectedClassFeatureFightingStyles.Contains(fightingStyle) && selectedClassFeatureFightingStyles.Count >= ClassFeatureFightingStyleChoiceCount)"
                                           @onchange="args => ToggleClassFeatureChoice(selectedClassFeatureFightingStyles, fightingStyle, ClassFeatureFightingStyleChoiceCount, args)" />
                                    @fightingStyle
                                </label>
                            }
                        </div>
                    </section>
                }
            </section>

            <section class="creator-step-screen @(IsStep("Feats") ? "" : "hidden")">
                <div class="creator-step-heading">
                    <p class="eyebrow">Feats</p>
                    <div class="creator-step-controls">
                        <button type="button" class="text-button no-margin" disabled="@IsFirstStep" @onclick="PreviousStep">Previous</button>
                        <button type="button" class="text-button no-margin" disabled="@IsLastStep" @onclick="NextStep">Next</button>
                    </div>
                </div>
                <ChoiceHintList Hints="@ChoiceHintsFor("Feats")" />
                @if (GrantedFeatSummaries.Count > 0)
                {
                    <section class="granted-feat-panel">
                        @foreach (var grantedFeat in GrantedFeatSummaries)
                        {
                            <article class="granted-feat-row">
                                <strong>@grantedFeat</strong>
                                <label class="switch-toggle">
                                    <input type="checkbox" @bind="applyGrantedFeats" @bind:after="RecomputeOptionEffectsAsync" />
                                    <span>Apply</span>
                                </label>
                            </article>
                        }
                    </section>
                }
                <label class="switch-toggle">
                    <input type="checkbox" @bind="showOnlyOriginFeats" @bind:after="OnOriginFeatFilterChanged" />
                    <span>Show only Origin Feats</span>
                </label>
                <select @bind="selectedFeatName" @bind:after="SelectFeatGroup">
                    <option value="">Select feat</option>
                    @foreach (var featGroup in FilteredFeatGroups)
                    {
                        <option value="@featGroup.Name">@featGroup.Name</option>
                    }
                </select>

                @if (selectedFeatGroup is not null)
                {
                    <button type="button" class="text-button" @onclick="AddFeat">Add Feat</button>
                }

                @if (newFeats.Count > 0)
                {
                    <section class="selected-class-list">
                        @foreach (var feat in newFeats)
                        {
                            <div class="selected-class-row">
                                <button type="button" class="text-link-button" @onclick="() => ShowFeatDetails(feat)">@feat.DisplayName</button>
                                <button type="button" class="icon-button" title="Remove feat" @onclick="() => RemoveFeat(feat)">-</button>
                            </div>
                        }
                    </section>
                }

                @if (ClassFeatureFeatChoiceRows.Count > 0)
                {
                    <section class="level-up-choice creator-class-feature-choice">
                        <p class="eyebrow">Class Feature Feats</p>
                        @foreach (var row in ClassFeatureFeatChoiceRows)
                        {
                            <label class="stacked-field">
                                <span>@row.ClassName level @row.SourceLevel: @row.FeatureName</span>
                                <select value="@GetClassFeatureFeatChoice(row.Key)" @onchange="args => SetClassFeatureFeatChoice(row.Key, args.Value?.ToString())">
                                    <option value="">Select feat</option>
                                    @foreach (var featDefinition in AvailableClassFeatureFeatDefinitions(row.Key))
                                    {
                                        <option value="@featDefinition.Id">@featDefinition.DisplayName</option>
                                    }
                                </select>
                            </label>
                        }
                    </section>
                }

            </section>

            <section class="creator-step-screen @(IsStep("Abilities") ? "" : "hidden")">
                <div class="creator-step-heading">
                    <p class="eyebrow">Abilities</p>
                    <div class="creator-step-controls">
                        <button type="button" class="text-button no-margin" disabled="@IsFirstStep" @onclick="PreviousStep">Previous</button>
                        <button type="button" class="text-button no-margin" disabled="@IsLastStep" @onclick="NextStep">Next</button>
                    </div>
                </div>
                <ChoiceHintList Hints="@ChoiceHintsFor("Abilities")" />
                <div class="ability-mode-switcher" aria-label="Ability score mode">
                    @foreach (var mode in AbilityScoreModes)
                    {
                        <button type="button"
                                class="source-version @(abilityScoreMode == mode ? "active" : "")"
                                @onclick="() => SetAbilityScoreMode(mode)">
                            @mode
                        </button>
                    }
                </div>

                @if (abilityScoreMode == "Manual")
                {
                    <div class="ability-grid">
                        @foreach (var ability in AbilityCodes)
                        {
                            <label>
                                <span>@ability.Label</span>
                                <input type="number" min="1" max="30" value="@GetAbilityValue(ability.Code)" @onchange="args => SetAbilityValue(ability.Code, args.Value?.ToString())" />
                            </label>
                        }
                    </div>
                }
                else if (abilityScoreMode == "Standard Array")
                {
                    <p class="muted compact-hint">Assign 15, 14, 13, 12, 10, and 8 once each.</p>
                    <div class="ability-assignment-grid">
                        @foreach (var ability in AbilityCodes)
                        {
                            <label>
                                <span>@ability.Label</span>
                                <select value="@GetAbilityBaseValue(ability.Code)" @onchange="args => AssignAbilityScore(ability.Code, args.Value?.ToString(), StandardArrayScores)">
                                    <option value="">Select score</option>
                                    @foreach (var score in StandardArrayScores)
                                    {
                                        <option value="@score" disabled="@IsAssignedScoreUnavailable(ability.Code, score, StandardArrayScores)">@score</option>
                                    }
                                </select>
                            </label>
                        }
                    </div>
                }
                else if (abilityScoreMode == "Point Buy")
                {
                    <div class="choice-counter @(PointBuyRemaining < 0 ? "invalid" : "")">
                        <span>Point buy remaining</span>
                        <strong>@PointBuyRemaining / 27</strong>
                    </div>
                    <div class="point-buy-grid">
                        @foreach (var ability in AbilityCodes)
                        {
                            var baseValue = GetAbilityBaseValue(ability.Code);
                            var bonus = GetAppliedAbilityBonus(ability.Code);
                            var finalValue = GetAbilityValue(ability.Code);
                            <article>
                                <span>@ability.Label</span>
                                <div class="point-buy-controls">
                                    <button type="button" class="mini-button" disabled="@(baseValue <= 8)" @onclick="() => ChangePointBuyScore(ability.Code, -1)">-</button>
                                    <strong>@finalValue</strong>
                                    <button type="button" class="mini-button" disabled="@(baseValue >= 15 || !CanIncreasePointBuyScore(ability.Code))" @onclick="() => ChangePointBuyScore(ability.Code, 1)">+</button>
                                </div>
                                <small>Base @baseValue@(bonus == 0 ? "" : $" + {bonus}") · Cost @PointBuyCost(baseValue)</small>
                            </article>
                        }
                    </div>
                }
                else if (abilityScoreMode == "Roll")
                {
                    <div class="ability-roll-toolbar">
                        <button type="button" class="text-button no-margin" @onclick="RollAbilityScores">Roll 4d6 drop lowest</button>
                        <span>@(rolledScores.Count == 0 ? "No rolls yet" : $"Rolled: {string.Join(", ", rolledScores)}")</span>
                    </div>
                    <div class="ability-assignment-grid">
                        @foreach (var ability in AbilityCodes)
                        {
                            <label>
                                <span>@ability.Label</span>
                                <select value="@GetAbilityBaseValue(ability.Code)" disabled="@(rolledScores.Count == 0)" @onchange="args => AssignAbilityScore(ability.Code, args.Value?.ToString(), rolledScores)">
                                    <option value="">Select roll</option>
                                    @foreach (var score in rolledScores)
                                    {
                                        <option value="@score" disabled="@IsAssignedScoreUnavailable(ability.Code, score, rolledScores)">@score</option>
                                    }
                                </select>
                            </label>
                        }
                    </div>
                }
            </section>

            <section class="creator-step-screen @(IsStep("Proficiencies") ? "" : "hidden")">
                <div class="creator-step-heading">
                    <p class="eyebrow">Proficiencies</p>
                    <div class="creator-step-controls">
                        <button type="button" class="text-button no-margin" disabled="@IsFirstStep" @onclick="PreviousStep">Previous</button>
                        <button type="button" class="text-button no-margin" disabled="@IsLastStep" @onclick="NextStep">Next</button>
                    </div>
                </div>
                <section class="creator-option-list proficiency-category-list" aria-label="Proficiency categories">
                    @foreach (var category in ProficiencySections)
                    {
                        <button type="button"
                                class="creator-option-row @(string.Equals(selectedProficiencySection, category, StringComparison.OrdinalIgnoreCase) ? "selected" : "")"
                                @onclick="() => SetProficiencySection(category)">
                            <span>@category</span>
                            <small>@BuildProficiencySectionSummary(category)</small>
                        </button>
                    }
                </section>
            </section>

            <section class="creator-step-screen review-step @(IsStep("Review") ? "" : "hidden")">
                <div class="creator-step-heading">
                    <p class="eyebrow">Review</p>
                    <div class="creator-step-controls">
                        <button type="button" class="text-button no-margin" disabled="@IsFirstStep" @onclick="PreviousStep">Previous</button>
                        <button type="button" class="text-button no-margin" disabled="@IsLastStep" @onclick="NextStep">Next</button>
                    </div>
                </div>
                <p class="muted compact-hint">Check the full summary on the right, then use Create when everything looks right.</p>
            </section>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <p class="validation-message">@errorMessage</p>
            }
        </section>

        <aside class="creator-detail-panel">
            @if (IsStep("Abilities"))
            {
                <section class="detail-section">
                    <h2>Ability Choices</h2>
                    @if (AllAbilityChoiceRequirements.Count == 0 && ChoiceHintsFor("Abilities").Count == 0)
                    {
                        <p class="muted">No additional ability choices are currently available.</p>
                    }
                    else
                    {
                        <AbilityChoiceList Requirements="AllAbilityChoiceRequirements"
                                           SelectedChoices="selectedAbilityChoices"
                                           OnChange="SetAbilityChoice"
                                           OnModeChange="SetAbilityChoiceMode"
                                           OnUnrestrictedChange="SetAbilityChoiceUnrestricted"
                                           EnableUnrestrictedBackgroundChoices="true" />
                        <ChoiceHintList Hints="@ChoiceHintsFor("Abilities")" />
                    }
                </section>
            }
            else if (IsStep("Proficiencies"))
            {
                <section class="detail-section">
                    <h2>@selectedProficiencySection</h2>
                    @if (selectedProficiencySection == "Saving Throws")
                    {
                        <ChoiceHintList Hints="@ChoiceHintsFor("Saving Throws")" />
                        <div class="proficiency-list detail-proficiency-list">
                            @foreach (var savingThrow in savingThrows)
                            {
                                <div class="proficiency-row">
                                    <div class="proficiency-main">
                                        <span>@savingThrow.AbilityName</span>
                                        <label class="toggle no-min"><input type="checkbox" @bind="savingThrow.IsProficient" /> Prof</label>
                                        <select @bind="savingThrow.RollMode">
                                            @foreach (var rollMode in RollModes)
                                            {
                                                <option value="@rollMode">@rollMode</option>
                                            }
                                        </select>
                                    </div>
                                    <input class="proficiency-notes" placeholder="Notes" @bind="savingThrow.Notes" @bind:event="oninput" />
                                </div>
                            }
                        </div>
                    }
                    else if (selectedProficiencySection == "Skills")
                    {
                        <ChoiceHintList Hints="@ChoiceHintsFor("Skills")" />
                        @if (SkillChoiceLimit > 0)
                        {
                            <div class="choice-counter @(!ManualSkillToolChoicesAreValid ? "invalid" : "")">
                                <span>Skill choices used</span>
                                <strong>@ManualSkillChoiceCount / @SkillChoiceLimit</strong>
                            </div>
                        }
                        @if (ClassFeatureExpertiseChoiceCount > 0)
                        {
                            <p class="muted compact-hint">Select @ClassFeatureExpertiseChoiceCount proficient skill(s) for Expertise.</p>
                            <div class="level-up-choice-grid">
                                @foreach (var skill in EligibleClassFeatureExpertiseSkills)
                                {
                                    <label class="toggle">
                                        <input type="checkbox"
                                               checked="@selectedClassFeatureExpertiseSkills.Contains(skill.Name)"
                                               disabled="@(!selectedClassFeatureExpertiseSkills.Contains(skill.Name) && selectedClassFeatureExpertiseSkills.Count >= ClassFeatureExpertiseChoiceCount)"
                                               @onchange="args => ToggleClassFeatureChoice(selectedClassFeatureExpertiseSkills, skill.Name, ClassFeatureExpertiseChoiceCount, args)" />
                                        @skill.Name
                                    </label>
                                }
                            </div>
                        }
                        @if (ClassFeatureSkillProficiencyChoiceCount > 0)
                        {
                            <p class="muted compact-hint">Select @ClassFeatureSkillProficiencyChoiceCount class feature skill proficiency/proficiencies.</p>
                            <div class="level-up-choice-grid">
                                @foreach (var skill in EligibleClassFeatureSkillProficiencyChoices)
                                {
                                    <label class="toggle">
                                        <input type="checkbox"
                                               checked="@selectedClassFeatureSkillProficiencies.Contains(skill.Name)"
                                               disabled="@(!selectedClassFeatureSkillProficiencies.Contains(skill.Name) && selectedClassFeatureSkillProficiencies.Count >= ClassFeatureSkillProficiencyChoiceCount)"
                                               @onchange="args => ToggleClassFeatureChoice(selectedClassFeatureSkillProficiencies, skill.Name, ClassFeatureSkillProficiencyChoiceCount, args)" />
                                        @skill.Name
                                    </label>
                                }
                            </div>
                        }
                        @if (ClassFeatureGrantsHalfProficiency)
                        {
                            <p class="muted compact-hint">Half-Proficiency will be applied to skills without proficiency or expertise.</p>
                        }
                        <div class="proficiency-list detail-proficiency-list">
                            @foreach (var skill in skills)
                            {
                                <div class="proficiency-row skill-row">
                                    <div class="proficiency-main">
                                        <span>@skill.Name <small>@skill.AbilityCode.ToUpperInvariant()</small></span>
                                        <label class="toggle no-min">
                                            <input type="checkbox"
                                                   checked="@skill.IsProficient"
                                                   disabled="@IsSkillChoiceDisabled(skill)"
                                                   @onchange="eventArgs => ToggleSkillProficiency(skill, eventArgs.Value is true)" />
                                            Prof
                                        </label>
                                        <select @bind="skill.RollMode">
                                            @foreach (var rollMode in RollModes)
                                            {
                                                <option value="@rollMode">@rollMode</option>
                                            }
                                        </select>
                                    </div>
                                    <input class="proficiency-notes" placeholder="Notes" @bind="skill.Notes" @bind:event="oninput" />
                                </div>
                            }
                        </div>
                    }
                    else if (selectedProficiencySection == "Tools")
                    {
                        <ChoiceHintList Hints="@ChoiceHintsFor("Tools")" />
                        @if (ToolChoiceLimit > 0)
                        {
                            <div class="choice-counter @(!ManualSkillToolChoicesAreValid ? "invalid" : "")">
                                <span>Tool choices used</span>
                                <strong>@ManualToolChoiceCount / @ToolChoiceLimit</strong>
                            </div>
                        }
                        @if (ClassFeatureToolProficiencyChoiceCount > 0)
                        {
                            <p class="muted compact-hint">Select @ClassFeatureToolProficiencyChoiceCount class feature tool proficiency/proficiencies.</p>
                            <div class="level-up-choice-grid">
                                @foreach (var tool in EligibleClassFeatureToolProficiencyChoices)
                                {
                                    <label class="toggle">
                                        <input type="checkbox"
                                               checked="@selectedClassFeatureToolProficiencies.Contains(tool.Name)"
                                               disabled="@(!selectedClassFeatureToolProficiencies.Contains(tool.Name) && selectedClassFeatureToolProficiencies.Count >= ClassFeatureToolProficiencyChoiceCount)"
                                               @onchange="args => ToggleClassFeatureChoice(selectedClassFeatureToolProficiencies, tool.Name, ClassFeatureToolProficiencyChoiceCount, args)" />
                                        @tool.Name
                                    </label>
                                }
                            </div>
                        }
                        <div class="proficiency-list detail-proficiency-list">
                            @foreach (var tool in toolProficiencies)
                            {
                                <div class="proficiency-row">
                                    <div class="proficiency-main two-column">
                                        <span>@tool.Name</span>
                                        <label class="toggle no-min">
                                            <input type="checkbox"
                                                   checked="@tool.IsProficient"
                                                   disabled="@IsToolChoiceDisabled(tool)"
                                                   @onchange="eventArgs => ToggleToolProficiency(tool, eventArgs.Value is true)" />
                                            Prof
                                        </label>
                                    </div>
                                    <input class="proficiency-notes" placeholder="Notes" @bind="tool.Notes" @bind:event="oninput" />
                                </div>
                            }
                        </div>
                    }
                    else if (selectedProficiencySection == "Languages")
                    {
                        <ChoiceHintList Hints="@ChoiceHintsFor("Languages")" />
                        @if (LanguageChoiceLimit > 0)
                        {
                            <div class="choice-counter @(ManualLanguageChoiceCount > LanguageChoiceLimit ? "invalid" : "")">
                                <span>Language choices used</span>
                                <strong>@ManualLanguageChoiceCount / @LanguageChoiceLimit</strong>
                            </div>
                        }
                        @if (ClassFeatureLanguageProficiencyChoiceCount > 0)
                        {
                            <p class="muted compact-hint">Select @ClassFeatureLanguageProficiencyChoiceCount class feature language(s).</p>
                            <div class="level-up-choice-grid">
                                @foreach (var language in EligibleClassFeatureLanguageProficiencyChoices)
                                {
                                    <label class="toggle">
                                        <input type="checkbox"
                                               checked="@selectedClassFeatureLanguageProficiencies.Contains(language.Name)"
                                               disabled="@(!selectedClassFeatureLanguageProficiencies.Contains(language.Name) && selectedClassFeatureLanguageProficiencies.Count >= ClassFeatureLanguageProficiencyChoiceCount)"
                                               @onchange="args => ToggleClassFeatureChoice(selectedClassFeatureLanguageProficiencies, language.Name, ClassFeatureLanguageProficiencyChoiceCount, args)" />
                                        @language.Name
                                    </label>
                                }
                            </div>
                        }
                        <div class="proficiency-list detail-proficiency-list">
                            @foreach (var language in languageProficiencies)
                            {
                                <div class="proficiency-row">
                                    <div class="proficiency-main two-column">
                                        <span>@language.Name</span>
                                        <label class="toggle no-min">
                                            <input type="checkbox"
                                                   checked="@language.IsProficient"
                                                   disabled="@IsLanguageChoiceDisabled(language)"
                                                   @onchange="eventArgs => ToggleLanguageProficiency(language, eventArgs.Value is true)" />
                                            Prof
                                        </label>
                                    </div>
                                    <input class="proficiency-notes" placeholder="Notes" @bind="language.Notes" @bind:event="oninput" />
                                </div>
                            }
                        </div>
                    }
                    <DefenseChoiceList Requirements="AllDefenseChoiceRequirements"
                                       SelectedChoices="selectedDefenseChoices"
                                       OnToggle="ToggleDefenseChoice" />
                </section>
            }
            else if (IsStep("Review"))
            {
                <section class="detail-section">
                    <h2>Character Summary</h2>
                    <dl class="detail-grid option-detail-grid">
                        <div><dt>Name</dt><dd>@(string.IsNullOrWhiteSpace(newName) ? "Unnamed character" : newName)</dd></div>
                        <div><dt>Ancestry</dt><dd>@(SelectedRace?.Name ?? "Not selected")</dd></div>
                        <div><dt>Background</dt><dd>@(SelectedBackground?.Name ?? "Not selected")</dd></div>
                        <div><dt>Classes</dt><dd>@(newClasses.Count == 0 ? "Not selected" : string.Join(" / ", newClasses.Select(characterClass => characterClass.DisplayName)))</dd></div>
                        <div><dt>Feats</dt><dd>@(BuildStoredFeats().Count == 0 ? "None" : string.Join(", ", BuildStoredFeats().Select(feat => feat.DisplayName)))</dd></div>
                        <div><dt>Abilities</dt><dd>STR @strength, DEX @dexterity, CON @constitution, INT @intelligence, WIS @wisdom, CHA @charisma</dd></div>
                        <div><dt>Saving Throws</dt><dd>@FormatSavingThrowSummary()</dd></div>
                        <div><dt>Skills</dt><dd>@FormatSkillSummary()</dd></div>
                        <div><dt>Tools</dt><dd>@FormatToolSummary()</dd></div>
                        <div><dt>Languages</dt><dd>@FormatLanguageSummary()</dd></div>
                        <div><dt>Ability Choices</dt><dd>@FormatAbilityChoiceSummary()</dd></div>
                        <div><dt>Defense Choices</dt><dd>@FormatDefenseChoiceSummary()</dd></div>
                    </dl>
                </section>
            }
            else if (SelectedDetail is null)
            {
                <div class="empty-detail">
                    <p class="eyebrow">Details</p>
                    <h2>Select an option</h2>
                    <p class="muted">Race, background, and feat details appear here while you build the character.</p>
                </div>
            }
            else
            {
                <header class="detail-header compact-detail-header">
                    <div>
                        <p class="eyebrow">@SelectedDetail.Kind</p>
                        <div class="detail-title-with-hint">
                            <h1>@SelectedDetail.Name</h1>
                            @if (ShouldShowBackgroundFeatHint)
                            {
                                <span>This background has feat choices saved for a later rule step.</span>
                            }
                        </div>
                        <p>@SelectedDetail.Source@(SelectedDetail.Page is null ? "" : $" p. {SelectedDetail.Page}")</p>
                    </div>
                </header>
                @if (detailKind == "Race" && selectedRaceGroup is not null)
                {
                    <div class="source-switcher detail-source-switcher">
                        @foreach (var version in selectedRaceGroup.Versions)
                        {
                            <button type="button"
                                    class="source-version @(version.Id == selectedRaceDefinitionId ? "active" : "")"
                                    @onclick="async () => await SelectRaceVersion(version)">
                                @version.Source
                            </button>
                        }
                    </div>

                    @if (RaceSizeOptions.Count > 1)
                    {
                        <label class="stacked-field detail-choice-field">
                            <span>Size</span>
                            <select @bind="selectedRaceSize">
                                @foreach (var size in RaceSizeOptions)
                                {
                                    <option value="@size">@FormatSize(size)</option>
                                }
                            </select>
                        </label>
                    }

                    @if (subraceDefinitions.Count > 0)
                    {
                        <label class="stacked-field detail-choice-field">
                            <span>Race version</span>
                            <select @bind="selectedSubraceDefinitionId" @bind:after="SelectSubrace">
                                <option value="" disabled="@IsSubraceRequired">@(IsSubraceRequired ? "Select race version" : "No version")</option>
                                @foreach (var subraceDefinition in subraceDefinitions)
                                {
                                    <option value="@subraceDefinition.Id">@subraceDefinition.DisplayName</option>
                                }
                            </select>
                        </label>
                        @if (IsSubraceRequired && SelectedSubrace is null)
                        {
                            <p class="validation-message compact-hint">Choose a race version to apply its traits and ability bonuses.</p>
                        }
                    }
                }
                else if (detailKind == "Background" && selectedBackgroundGroup is not null)
                {
                    <div class="source-switcher detail-source-switcher">
                        @foreach (var version in selectedBackgroundGroup.Versions)
                        {
                            <button type="button"
                                    class="source-version @(version.Id == selectedBackgroundDefinitionId ? "active" : "")"
                                    @onclick="async () => await SelectBackgroundVersion(version)">
                                @version.Source
                            </button>
                        }
                    </div>
                }
                else if (detailKind == "Class" && selectedClassGroup is not null)
                {
                    <div class="source-switcher detail-source-switcher">
                        @foreach (var version in selectedClassGroup.Versions)
                        {
                            <button type="button"
                                    class="source-version @(version.Id == selectedClassDefinitionId ? "active" : "")"
                                    @onclick="async () => await SelectClassVersion(version)">
                                @version.Source
                            </button>
                        }
                    </div>
                }
                else if (detailKind == "Feat" && selectedFeatGroup is not null)
                {
                    <div class="source-switcher detail-source-switcher">
                        @foreach (var version in selectedFeatGroup.Versions)
                        {
                            <button type="button"
                                    class="source-version @(version.Id == selectedFeatDefinitionId ? "active" : "")"
                                    @onclick="async () => await SelectFeatVersion(version)">
                                @version.Source
                            </button>
                        }
                    </div>
                }

                <dl class="detail-grid option-detail-grid">
                    @foreach (var stat in SelectedDetail.Stats)
                    {
                        <div class="@BuildDetailStatClass(stat.Label)"><dt>@stat.Label</dt><dd>@stat.Value</dd></div>
                    }
                </dl>

                @foreach (var detailSection in SelectedDetail.Sections)
                {
                    <section class="detail-section">
                        <h2>@detailSection.Title</h2>
                        @foreach (var paragraph in detailSection.Paragraphs)
                        {
                            <p><MarkupText Text="@paragraph" /></p>
                        }
                    </section>
                }

                @foreach (var featureGroup in SelectedDetail.FeatureGroups)
                {
                    <section class="detail-section class-feature-section">
                        <h2>@featureGroup.Title</h2>
                        <div class="feature-level-list">
                            @foreach (var levelGroup in featureGroup.Levels)
                            {
                                <article class="feature-level-row">
                                    <span class="feature-level-badge">Lvl @levelGroup.Level</span>
                                    <div>
                                        @foreach (var feature in levelGroup.Features)
                                        {
                                            <details class="feature-detail-toggle">
                                                <summary class="feature-pill">@feature.Name</summary>
                                                @if (feature.Paragraphs.Count == 0)
                                                {
                                                    <p class="muted compact-hint">No detail text available.</p>
                                                }
                                                else
                                                {
                                                    <div class="feature-detail-body">
                                                        @foreach (var paragraph in feature.Paragraphs)
                                                        {
                                                            <p><MarkupText Text="@paragraph" /></p>
                                                        }
                                                    </div>
                                                }
                                            </details>
                                        }
                                    </div>
                                </article>
                            }
                        </div>
                    </section>
                }

                @if (SelectedDetail.ProgressionTables.Count > 0)
                {
                    <details class="detail-section progression-details">
                        <summary>Spellprogression</summary>
                        @foreach (var table in SelectedDetail.ProgressionTables)
                        {
                            <section class="progression-table-block">
                                <h3>@table.Title</h3>
                                <div class="progression-table-scroll">
                                    <table class="progression-table">
                                        <thead>
                                            <tr>
                                                @foreach (var column in table.Columns)
                                                {
                                                    <th>@column</th>
                                                }
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var row in table.Rows)
                                            {
                                                <tr>
                                                    @foreach (var value in row.Values)
                                                    {
                                                        <td><MarkupText Text="@value" /></td>
                                                    }
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </section>
                        }
                    </details>
                }
            }
        </aside>
    </section>
</section>

@code {
    private List<ClassDefinition> classDefinitions = [];
