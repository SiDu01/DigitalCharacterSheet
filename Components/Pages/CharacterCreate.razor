    protected override async Task OnInitializedAsync()
    {
        classDefinitions = (await Database.GetClassDefinitionsAsync()).ToList();
        raceDefinitions = (await Database.GetRaceDefinitionsAsync()).ToList();
        backgroundDefinitions = (await Database.GetBackgroundDefinitionsAsync()).ToList();
        featDefinitions = (await Database.GetFeatDefinitionsAsync()).ToList();

        classGroups = classDefinitions
            .GroupBy(classDefinition => classDefinition.Name, StringComparer.OrdinalIgnoreCase)
            .Select(group => new ClassGroup(group))
            .OrderBy(group => group.Name)
            .ToList();
        raceGroups = raceDefinitions
            .GroupBy(definition => definition.Name, StringComparer.OrdinalIgnoreCase)
            .Select(group => new RaceGroup(group))
            .OrderBy(group => group.Name)
            .ToList();
        backgroundGroups = backgroundDefinitions
            .GroupBy(definition => definition.Name, StringComparer.OrdinalIgnoreCase)
            .Select(group => new BackgroundGroup(group))
            .OrderBy(group => group.Name)
            .ToList();
        featGroups = featDefinitions
            .GroupBy(definition => definition.Name, StringComparer.OrdinalIgnoreCase)
            .Select(group => new FeatGroup(group))
            .OrderBy(group => group.Name)
            .ToList();
    }

    private bool IsStep(string step)
    {
        return string.Equals(currentStep, step, StringComparison.OrdinalIgnoreCase);
    }

    private void SetStep(string step)
    {
        if (CreationSteps.Any(candidate => string.Equals(candidate.Key, step, StringComparison.OrdinalIgnoreCase)))
        {
            currentStep = step;
            RefreshDetailForStep();
        }
    }

    private void NextStep()
    {
        if (!IsLastStep)
        {
            SetStep(CreationSteps[CurrentStepIndex + 1].Key);
        }
    }

    private void PreviousStep()
    {
        if (!IsFirstStep)
        {
            SetStep(CreationSteps[CurrentStepIndex - 1].Key);
        }
    }

    private void RefreshDetailForStep()
    {
        detailKind = currentStep switch
        {
            "Ancestry" when SelectedRace is not null => "Race",
            "Background" when SelectedBackground is not null => "Background",
            "Classes" when SelectedClass is not null => "Class",
            "Feats" when SelectedFeat is not null => "Feat",
            _ => ""
        };
    }

    private void SetAbilityScoreMode(string mode)
    {
        if (!AbilityScoreModes.Contains(mode))
        {
            return;
        }

        abilityScoreMode = mode;
        if (mode == "Point Buy")
        {
            foreach (var ability in AbilityCodes)
            {
                SetAbilityBaseValue(ability.Code, Math.Clamp(GetAbilityBaseValue(ability.Code), 8, 15));
            }
        }
        else if (mode == "Standard Array")
        {
            ApplyScoresInOrder(StandardArrayScores);
        }
        else if (mode == "Roll" && rolledScores.Count > 0)
        {
            ApplyScoresInOrder(rolledScores);
        }
    }

    private int GetAbilityValue(string abilityCode)
    {
        return abilityCode switch
        {
            "str" => strength,
            "dex" => dexterity,
            "con" => constitution,
            "int" => intelligence,
            "wis" => wisdom,
            "cha" => charisma,
            _ => 10
        };
    }

    private int GetAbilityBaseValue(string abilityCode)
    {
        return Math.Clamp(GetAbilityValue(abilityCode) - GetAppliedAbilityBonus(abilityCode), 1, 30);
    }

    private int GetAppliedAbilityBonus(string abilityCode)
    {
        return appliedAbilityBonuses.GetValueOrDefault(abilityCode);
    }

    private void SetAbilityBaseValue(string abilityCode, int value)
    {
        SetAbilityValue(abilityCode, Math.Clamp(value + GetAppliedAbilityBonus(abilityCode), 1, 30));
    }

    private void SetAbilityValue(string abilityCode, string? value)
    {
        if (!int.TryParse(value, out var parsed))
        {
            return;
        }

        SetAbilityValue(abilityCode, Math.Clamp(parsed, 1, 30));
    }

    private void SetAbilityValue(string abilityCode, int value)
    {
        switch (abilityCode)
        {
            case "str":
                strength = value;
                break;
            case "dex":
                dexterity = value;
                break;
            case "con":
                constitution = value;
                break;
            case "int":
                intelligence = value;
                break;
            case "wis":
                wisdom = value;
                break;
            case "cha":
                charisma = value;
                break;
        }
    }

    private void AssignAbilityScore(string abilityCode, string? value, IReadOnlyList<int> availableScores)
    {
        if (!int.TryParse(value, out var score) || !availableScores.Contains(score))
        {
            return;
        }

        SetAbilityBaseValue(abilityCode, score);
    }

    private bool IsAssignedScoreUnavailable(string abilityCode, int score, IReadOnlyList<int> availableScores)
    {
        var selectedIndex = availableScores
            .Select((value, index) => new { value, index })
            .Where(entry => entry.value == score)
            .Select(entry => entry.index)
            .ToList();
        if (selectedIndex.Count > 1)
        {
            var usedCount = AbilityCodes
                .Where(ability => ability.Code != abilityCode)
                .Count(ability => GetAbilityBaseValue(ability.Code) == score);
            return usedCount >= selectedIndex.Count;
        }

        return AbilityCodes.Any(ability => ability.Code != abilityCode && GetAbilityBaseValue(ability.Code) == score);
    }

    private void ChangePointBuyScore(string abilityCode, int delta)
    {
        var current = GetAbilityBaseValue(abilityCode);
        var next = Math.Clamp(current + delta, 8, 15);
        if (next > current && !CanIncreasePointBuyScore(abilityCode))
        {
            return;
        }

        SetAbilityBaseValue(abilityCode, next);
    }

    private bool CanIncreasePointBuyScore(string abilityCode)
    {
        var current = GetAbilityBaseValue(abilityCode);
        if (current >= 15)
        {
            return false;
        }

        var additionalCost = PointBuyCost(current + 1) - PointBuyCost(current);
        return PointBuyRemaining >= additionalCost;
    }

    private static int PointBuyCost(int score)
    {
        return score switch
        {
            <= 8 => 0,
            9 => 1,
            10 => 2,
            11 => 3,
            12 => 4,
            13 => 5,
            14 => 7,
            _ => 9
        };
    }

    private void RollAbilityScores()
    {
        rolledScores = Enumerable.Range(0, 6)
            .Select(_ => RollSingleAbilityScore())
            .OrderByDescending(score => score)
            .ToList();
        ApplyScoresInOrder(rolledScores);
    }

    private static int RollSingleAbilityScore()
    {
        var rolls = Enumerable.Range(0, 4)
            .Select(_ => Random.Shared.Next(1, 7))
            .OrderByDescending(value => value)
            .Take(3);
        return rolls.Sum();
    }

    private void ApplyScoresInOrder(IReadOnlyList<int> scores)
    {
        for (var index = 0; index < AbilityCodes.Length && index < scores.Count; index++)
        {
            SetAbilityBaseValue(AbilityCodes[index].Code, scores[index]);
        }
    }

