    private string BuildRaceChoicesJson(bool includeAbilityChoices = true)
    {
        var choices = new Dictionary<string, object>();
        if (!string.IsNullOrWhiteSpace(selectedRaceSize))
        {
            choices["size"] = selectedRaceSize;
        }
        if (!applyGrantedFeats)
        {
            choices["applyGrantedFeats"] = false;
        }

        AddDefenseChoices(choices, RaceDefenseChoiceRequirements);
        if (includeAbilityChoices)
        {
            AddAbilityChoices(choices, RaceAbilityChoiceRequirements);
        }
        return choices.Count == 0 ? "{}" : JsonSerializer.Serialize(choices);
    }

    private string BuildBackgroundChoicesJson(bool includeAbilityChoices = true)
    {
        var choices = new Dictionary<string, object>();
        if (!applyGrantedFeats)
        {
            choices["applyGrantedFeats"] = false;
        }

        AddDefenseChoices(choices, BackgroundDefenseChoiceRequirements);
        if (includeAbilityChoices)
        {
            AddAbilityChoices(choices, BackgroundAbilityChoiceRequirements);
        }
        return choices.Count == 0 ? "{}" : JsonSerializer.Serialize(choices);
    }

    private string BuildFeatChoicesJson(bool includeAbilityChoices = true)
    {
        var choices = new Dictionary<string, object>();
        AddDefenseChoices(choices, FeatDefenseChoiceRequirements);
        if (includeAbilityChoices)
        {
            AddAbilityChoices(choices, FeatAbilityChoiceRequirements);
        }
        return choices.Count == 0 ? "{}" : JsonSerializer.Serialize(choices);
    }

    private void AddDefenseChoices(Dictionary<string, object> choices, IReadOnlyList<CharacterDefenseChoiceRequirement> requirements)
    {
        var selected = requirements
            .Where(requirement => selectedDefenseChoices.TryGetValue(requirement.Key, out var values) && values.Count > 0)
            .ToDictionary(
                requirement => requirement.Key,
                requirement => selectedDefenseChoices[requirement.Key].Take(requirement.Count).ToList(),
                StringComparer.OrdinalIgnoreCase);
        if (selected.Count > 0)
        {
            choices["defenseChoices"] = selected;
        }
    }

    private void AddAbilityChoices(Dictionary<string, object> choices, IReadOnlyList<CharacterAbilityChoiceRequirement> requirements)
    {
        var activeRequirements = CharacterAbilityChoiceService.GetActiveRequirements(requirements, selectedAbilityChoices);
        var selected = activeRequirements
            .Where(requirement => selectedAbilityChoices.TryGetValue(requirement.Key, out var values) && values.Count > 0)
            .ToDictionary(
                requirement => requirement.Key,
                requirement => selectedAbilityChoices[requirement.Key]
                    .Where(value => requirement.Options.Contains(value, StringComparer.OrdinalIgnoreCase))
                    .Take(requirement.Count)
                    .ToList(),
                StringComparer.OrdinalIgnoreCase);
        foreach (var marker in selectedAbilityChoices
            .Where(pair => pair.Value.Count > 0
                && (pair.Key.EndsWith(":mode", StringComparison.OrdinalIgnoreCase)
                    || pair.Key.EndsWith(":unrestricted", StringComparison.OrdinalIgnoreCase))))
        {
            selected[marker.Key] = marker.Value.ToList();
        }

        if (selected.Count > 0)
        {
            choices["abilityChoices"] = selected;
        }
    }

    private async Task SetAbilityChoice((string Key, int Index, string Value) choice)
    {
        var requirement = AllAbilityChoiceRequirements
            .Select(requirement => CharacterAbilityChoiceService.ApplyUnrestrictedOptions(requirement, selectedAbilityChoices))
            .FirstOrDefault(requirement => string.Equals(requirement.Key, choice.Key, StringComparison.OrdinalIgnoreCase));
        if (requirement is null || choice.Index < 0 || choice.Index >= requirement.Count)
        {
            return;
        }

        if (!selectedAbilityChoices.TryGetValue(choice.Key, out var values))
        {
            values = [];
            selectedAbilityChoices[choice.Key] = values;
        }

        while (values.Count <= choice.Index)
        {
            values.Add("");
        }

        values[choice.Index] = requirement.Options.Contains(choice.Value, StringComparer.OrdinalIgnoreCase) ? choice.Value : "";
        values.RemoveAll(string.IsNullOrWhiteSpace);
        if (values.Count == 0)
        {
            selectedAbilityChoices.Remove(choice.Key);
        }

        await RecomputeOptionEffectsAsync();
    }

    private async Task SetAbilityChoiceMode((string ModeGroupKey, string ModeKey) choice)
    {
        foreach (var requirement in AllAbilityChoiceRequirements.Where(requirement => string.Equals(requirement.ModeGroupKey, choice.ModeGroupKey, StringComparison.OrdinalIgnoreCase)))
        {
            selectedAbilityChoices.Remove(requirement.Key);
        }

        selectedAbilityChoices[CharacterAbilityChoiceService.BuildModeMarkerKey(choice.ModeGroupKey)] = [choice.ModeKey];
        await RecomputeOptionEffectsAsync();
    }

    private async Task SetAbilityChoiceUnrestricted((string ModeGroupKey, bool IsUnrestricted) choice)
    {
        var markerKey = CharacterAbilityChoiceService.BuildUnrestrictedMarkerKey(choice.ModeGroupKey);
        if (choice.IsUnrestricted)
        {
            selectedAbilityChoices[markerKey] = ["true"];
        }
        else
        {
            selectedAbilityChoices.Remove(markerKey);
            foreach (var requirement in AllAbilityChoiceRequirements.Where(requirement => string.Equals(requirement.ModeGroupKey, choice.ModeGroupKey, StringComparison.OrdinalIgnoreCase)))
            {
                if (!selectedAbilityChoices.TryGetValue(requirement.Key, out var values))
                {
                    continue;
                }

                values.RemoveAll(value => !requirement.Options.Contains(value, StringComparer.OrdinalIgnoreCase));
                if (values.Count == 0)
                {
                    selectedAbilityChoices.Remove(requirement.Key);
                }
            }
        }

        await RecomputeOptionEffectsAsync();
    }

    private void ToggleDefenseChoice((string Key, string Option, bool IsSelected) choice)
    {
        var requirement = AllDefenseChoiceRequirements.FirstOrDefault(requirement => string.Equals(requirement.Key, choice.Key, StringComparison.OrdinalIgnoreCase));
        if (requirement is null)
        {
            return;
        }

        if (!selectedDefenseChoices.TryGetValue(choice.Key, out var values))
        {
            values = [];
            selectedDefenseChoices[choice.Key] = values;
        }

        if (choice.IsSelected)
        {
            if (!values.Contains(choice.Option, StringComparer.OrdinalIgnoreCase) && values.Count < requirement.Count)
            {
                values.Add(choice.Option);
            }

            return;
        }

        values.RemoveAll(value => string.Equals(value, choice.Option, StringComparison.OrdinalIgnoreCase));
        if (values.Count == 0)
        {
            selectedDefenseChoices.Remove(choice.Key);
        }
    }

