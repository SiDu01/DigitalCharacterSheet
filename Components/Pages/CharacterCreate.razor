    private async Task AddClass()
    {
        errorMessage = "";

        var classDefinition = selectedClassDefinitionId is null
            ? null
            : classDefinitions.FirstOrDefault(definition => definition.Id == selectedClassDefinitionId.Value);

        if (classDefinition is null)
        {
            errorMessage = "Please select a class.";
            return;
        }

        if (selectedClassLevel is < 1 or > 20)
        {
            errorMessage = "Class level must be between 1 and 20.";
            return;
        }

        if (newClasses.Any(characterClass => string.Equals(characterClass.ClassName, classDefinition.Name, StringComparison.OrdinalIgnoreCase)))
        {
            errorMessage = "This class is already added.";
            return;
        }

        var subclassDefinition = selectedSubclassDefinitionId is null
            ? null
            : subclassDefinitions.FirstOrDefault(definition => definition.Id == selectedSubclassDefinitionId.Value);

        newClasses.Add(new CharacterClass
        {
            ClassDefinitionId = classDefinition.Id,
            SubclassDefinitionId = subclassDefinition?.Id,
            ClassName = classDefinition.Name,
            ClassSource = classDefinition.Source,
            SubclassName = subclassDefinition?.Name ?? "",
            SubclassSource = subclassDefinition?.Source ?? "",
            Level = selectedClassLevel
        });
        if (subclassDefinition is not null)
        {
            addedSubclassDefinitions[subclassDefinition.Id] = subclassDefinition;
        }

        primaryClassDefinitionId ??= classDefinition.Id;

        selectedClassName = "0";
        selectedClassGroup = null;
        selectedClassDefinitionId = null;
        selectedSubclassDefinitionId = null;
        subclassDefinitions = [];
        selectedClassLevel = 1;
        PruneDefenseChoices();
        PruneAbilityChoices();
        PruneClassFeatureChoices();
        await RecomputeOptionEffectsAsync();
    }

    private async Task RemoveClass(CharacterClass characterClass)
    {
        newClasses.Remove(characterClass);
        if (characterClass.SubclassDefinitionId is not null
            && newClasses.All(existing => existing.SubclassDefinitionId != characterClass.SubclassDefinitionId))
        {
            addedSubclassDefinitions.Remove(characterClass.SubclassDefinitionId.Value);
        }
        if (primaryClassDefinitionId == characterClass.ClassDefinitionId)
        {
            primaryClassDefinitionId = newClasses.FirstOrDefault()?.ClassDefinitionId;
        }
        PruneDefenseChoices();
        PruneClassFeatureChoices();
        PruneAbilityChoices();
        await RecomputeOptionEffectsAsync();
    }

