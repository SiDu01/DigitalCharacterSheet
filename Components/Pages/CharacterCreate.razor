    private async Task<RaceDefinition?> ResolvePreferredRaceVersionAsync(RaceGroup? raceGroup)
    {
        if (raceGroup is null)
        {
            return null;
        }

        await LoadSubraceCountsForRaceGroupAsync(raceGroup);
        var versionsWithSubraces = raceGroup.Versions
            .Where(version => GetRaceVersionSubraceCount(version) > 0)
            .ToList();

        return versionsWithSubraces.Count == 1 && GetRaceVersionSubraceCount(raceGroup.Primary) == 0
            ? versionsWithSubraces[0]
            : raceGroup.Primary;
    }

    private async Task LoadSubraceCountsForRaceGroupAsync(RaceGroup raceGroup)
    {
        foreach (var version in raceGroup.Versions)
        {
            await GetSubraceDefinitionsForRaceVersionAsync(version);
        }
    }

    private async Task<IReadOnlyList<SubraceDefinition>> GetSubraceDefinitionsForRaceVersionAsync(RaceDefinition raceDefinition)
    {
        if (!subraceDefinitionsByRaceVersion.TryGetValue(raceDefinition.Id, out var cached))
        {
            cached = (await Database.GetSubraceDefinitionsAsync(raceDefinition.Id)).ToList();
            subraceDefinitionsByRaceVersion[raceDefinition.Id] = cached;
