    private async Task CreateCharacter()
    {
        errorMessage = "";

        if (string.IsNullOrWhiteSpace(newName))
        {
            errorMessage = "Please enter a character name.";
            return;
        }

        if (IsSubraceRequired && SelectedSubrace is null)
        {
            currentStep = "Ancestry";
            detailKind = "Race";
            errorMessage = "Please select a race version.";
            return;
        }

        if (HasClassFeatureChoices && !ClassFeatureChoicesAreComplete)
        {
            currentStep = GetFirstIncompleteClassFeatureStep();
            detailKind = "Class";
            errorMessage = "Please complete the class feature choices for the selected starting levels.";
            return;
        }

        try
        {
            isCreating = true;
            await RecomputeOptionEffectsAsync();
            var character = await Database.AddCharacterAsync(BuildDraftCharacter());
            var grantedEffects = BuildClassFeatureGrantedEffects(character.Id).ToList();
            if (grantedEffects.Count > 0)
            {
                await Database.AddCharacterGrantedEffectsAsync(character.Id, grantedEffects);
            }

            Navigation.NavigateTo($"characters/{character.Id}");
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not create character: {ex.Message}";
        }
        finally
        {
            isCreating = false;
        }
    }

