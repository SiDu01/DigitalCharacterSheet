    private static string FormatTrackedChoice(string name, bool isProficient, string rollMode, string notes)
    {
        var parts = new List<string>();
        if (isProficient)
        {
            parts.Add("Prof");
        }
        if (rollMode != "Normal")
        {
            parts.Add(rollMode);
        }
        if (!string.IsNullOrWhiteSpace(notes))
        {
            parts.Add(notes);
        }

        return parts.Count == 0 ? name : $"{name} ({string.Join("; ", parts)})";
    }

    private IEnumerable<string> BuildGrantedFeatSummaries()
    {
        foreach (var featReference in ReadGrantedFeatReferences(SelectedRace?.RawJson))
        {
            yield return FormatGrantedFeatReference(featReference);
        }

        foreach (var featReference in ReadGrantedFeatReferences(SelectedSubrace?.RawJson))
        {
            yield return FormatGrantedFeatReference(featReference);
        }

        foreach (var featReference in ReadGrantedFeatReferences(SelectedBackground?.FeatsJson))
        {
            yield return FormatGrantedFeatReference(featReference);
        }
    }

    private string FormatGrantedFeatReference((string Name, string Source) featReference)
    {
        var featDefinition = featDefinitions.FirstOrDefault(definition =>
            string.Equals(definition.Name, featReference.Name, StringComparison.OrdinalIgnoreCase)
            && (string.IsNullOrWhiteSpace(featReference.Source)
                || string.Equals(definition.Source, featReference.Source, StringComparison.OrdinalIgnoreCase)));
        return featDefinition is null
            ? featReference.Name
            : featDefinition.DisplayName;
    }

    private static IEnumerable<(string Name, string Source)> ReadGrantedFeatReferences(string? rawJson)
    {
        if (string.IsNullOrWhiteSpace(rawJson))
        {
            yield break;
        }

        using var document = JsonDocument.Parse(rawJson);
        var featsElement = document.RootElement;
        if (document.RootElement.ValueKind == JsonValueKind.Object
            && !document.RootElement.TryGetProperty("feats", out featsElement))
        {
            yield break;
        }

        if (featsElement.ValueKind != JsonValueKind.Array)
        {
            yield break;
        }

        foreach (var entry in featsElement.EnumerateArray())
        {
            if (entry.ValueKind != JsonValueKind.Object)
            {
                continue;
            }

            foreach (var property in entry.EnumerateObject())
            {
                if (property.Value.ValueKind != JsonValueKind.True)
                {
                    continue;
                }

                var parts = property.Name.Split('|', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
                if (parts.Length > 0)
                {
                    yield return (parts[0], parts.Length > 1 ? parts[1].ToUpperInvariant() : "");
                }
            }
        }
    }

    private static bool IsOriginFeat(FeatDefinition feat)
