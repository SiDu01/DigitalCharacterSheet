        return "Proficiencies";
    }

    private IEnumerable<CharacterGrantedEffect> BuildClassFeatureGrantedEffects(int characterId)
    {
        var source = GetClassFeatureEffectSource();
        if (source is null)
        {
            yield break;
        }

        foreach (var fightingStyle in selectedClassFeatureFightingStyles)
        {
            yield return BuildClassFeatureGrantedEffect(characterId, source, "FightingStyle", fightingStyle, source.ClassSource, "Chosen during character creation.");
        }

        foreach (var skillName in selectedClassFeatureExpertiseSkills)
        {
            yield return BuildClassFeatureGrantedEffect(characterId, source, "SkillExpertise", skillName, "Expertise", "Chosen during character creation.");
        }

        foreach (var skillName in selectedClassFeatureSkillProficiencies)
        {
            yield return BuildClassFeatureGrantedEffect(characterId, source, "SkillProficiency", skillName, "Proficient", "Chosen during character creation.");
        }

        foreach (var toolName in selectedClassFeatureToolProficiencies)
        {
            yield return BuildClassFeatureGrantedEffect(characterId, source, "ToolProficiency", toolName, "Proficient", "Chosen during character creation.");
        }

        foreach (var languageName in selectedClassFeatureLanguageProficiencies)
        {
            yield return BuildClassFeatureGrantedEffect(characterId, source, "LanguageProficiency", languageName, "Proficient", "Chosen during character creation.");
        }

        if (ClassFeatureGrantsHalfProficiency)
        {
            yield return BuildClassFeatureGrantedEffect(characterId, source, "SkillHalfProficiency", "AllSkills", "Half", "Chosen during character creation.");
        }
    }

    private ClassFeatureEffectSource? GetClassFeatureEffectSource()
    {
        var sourceClass = newClasses
            .OrderByDescending(characterClass => characterClass.Level)
            .FirstOrDefault(characterClass => characterClass.ClassDefinitionId > 0);
        return sourceClass is null
