    private bool ClassFeatureChoicesAreComplete => ClassFeatureFeatChoiceRows.All(row => selectedClassFeatureFeatIds.ContainsKey(row.Key))
        && AbilityChoicesAreComplete(ClassFeatureAbilityChoiceRequirements)
