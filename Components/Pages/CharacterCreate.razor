    private int PointBuyRemaining => 27 - PointBuySpent;
    private int CurrentStepIndex => Math.Max(0, CreationSteps.ToList().FindIndex(step => step.Key == currentStep));
    private bool IsFirstStep => CurrentStepIndex == 0;
    private bool IsLastStep => CurrentStepIndex >= CreationSteps.Count - 1;
    private string CurrentStepLabel => CreationSteps[CurrentStepIndex].Label;
    private bool IsSubraceRequired => subraceDefinitions.Count > 0;
    private OptionDetail? SelectedDetail => detailKind switch
