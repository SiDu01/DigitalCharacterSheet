@page "/library"
@page "/library/{EntryId:int}"
@using System.Text.Json
@inject AppDatabase Database
@inject NavigationManager Navigation
@inject RecentActivityService RecentActivity

<PageTitle>Library</PageTitle>

<section class="spell-page library-page">
    <header class="page-header">
        <div>
            <p class="eyebrow">Compendium</p>
            <h1>@(string.IsNullOrWhiteSpace(selectedCategory) ? "Library" : selectedCategory)</h1>
        </div>
        <div class="header-actions">
            @if (!string.IsNullOrWhiteSpace(selectedCategory))
            {
                <button type="button" class="text-button no-margin" @onclick="ShowCategories">Categories</button>
            }
            <div class="spell-count">@VisibleCountText</div>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(loadError))
    {
        <section class="sheet-panel">
            <p class="eyebrow">Database error</p>
            <pre class="error-details">@loadError</pre>
        </section>
    }
    else if (isLoading)
    {
        <p class="muted">Preparing library...</p>
    }
    else if (string.IsNullOrWhiteSpace(selectedCategory))
    {
        <section class="item-category-grid">
            @foreach (var tile in CategoryTiles)
            {
                <button type="button" class="item-category-tile" @onclick="() => OpenCategory(tile.Category)">
                    <span class="item-category-count">@tile.Count</span>
                    <strong>@tile.Category</strong>
                    <small>@tile.Description</small>
                </button>
            }
        </section>
    }
    else
    {
        <section class="spell-toolbar">
            <input class="search-input" placeholder="@($"Search {selectedCategory}")" @bind="searchText" @bind:event="oninput" />
        </section>

        <section class="spell-master-detail">
            <section class="spell-list spell-list-pane">
                @foreach (var group in FilteredGroups)
                {
                    var entry = group.ResolveVersion(selectedEntry);
                    <article class="spell-row @(selectedGroup?.Name == group.Name ? "selected" : "")" @onclick="() => OpenEntry(group)">
                        <div class="spell-main">
                            <div class="spell-title">
                                <h2>@group.Name</h2>
                                <span class="source-badge">@entry.Type</span>
                            </div>
                            <div class="spell-meta">
                                @foreach (var source in group.Versions.Select(version => version.Source).Distinct())
                                {
                                    <span class="source-badge">@source</span>
                                }
                            </div>
                        </div>
                    </article>
                }
            </section>

            <aside class="spell-detail-pane">
                @if (selectedEntry is null)
                {
                    <div class="empty-detail">
                        <p class="eyebrow">@selectedCategory</p>
                        <h2>Select an entry</h2>
                        <p class="muted">Library entries are lookup-only and do not change characters.</p>
                    </div>
                }
                else
                {
                    <section class="sheet-panel spell-detail-card">
                        <header class="detail-header compact-detail-header">
                            <div>
                                <p class="eyebrow">@selectedEntry.Category</p>
                                <h2>@selectedEntry.Name</h2>
                                <div class="spell-meta">
                                    <span>@selectedEntry.Type</span>
                                    <span>@selectedEntry.Source</span>
                                    @if (selectedEntry.Page is not null)
                                    {
                                        <span>p. @selectedEntry.Page</span>
                                    }
                                </div>
                            </div>
                            <button class="icon-button bookmark-button @(IsSelectedEntryBookmarked ? "active" : "")"
                                    title="Toggle bookmark"
                                    @onclick="ToggleSelectedBookmark">
                                @(IsSelectedEntryBookmarked ? "★" : "☆")
                            </button>
                        </header>

                        @if (selectedGroup?.Versions.Count > 1)
                        {
                            <div class="source-switcher">
                                @foreach (var version in selectedGroup.Versions)
                                {
                                    <button type="button"
                                            class="source-version @(version.Id == selectedEntry.Id ? "active" : "")"
                                            @onclick="() => SelectVersion(version)">
                                        @version.Source
                                    </button>
                                }
                            </div>
                        }

                        @if (RelatedGroups.Count > 0)
                        {
                            <section class="detail-section">
                                <h2>@RelatedTitle</h2>
                                <div class="source-switcher">
                                    @foreach (var related in RelatedGroups)
                                    {
                                        <button type="button"
                                                class="source-version @(activeRelatedLabels.Contains(related.Label) ? "active" : "")"
                                                @onclick="() => ToggleRelatedGroup(related)">
                                            @related.Label
                                        </button>
                                    }
                                </div>
                                @foreach (var group in ActiveRelatedGroups.Where(group => group.Versions.Count > 1))
                                {
                                    <div class="source-switcher">
                                        <span class="source-badge">@group.Label</span>
                                        @foreach (var version in group.Versions)
                                        {
                                            <button type="button"
                                                    class="source-version @(version.Id == ResolveRelatedEntry(group).Id ? "active" : "")"
                                                    @onclick="() => SelectRelatedVersion(group, version)">
                                                @version.Source
                                            </button>
                                        }
                                    </div>
                                }
                            </section>
                        }

                        @if (IsClassEntry(selectedEntry))
                        {
                            @ClassFeatureSections(selectedEntry, ActiveRelatedEntries)
                        }
                        else
                        {
                            @EntryParagraphs(selectedEntry)
                            @foreach (var group in ActiveRelatedGroups)
                            {
                                <section class="detail-section">
                                    <h2>@group.Label</h2>
                                    @if (group.Versions.Count > 1)
                                    {
                                        <div class="source-switcher">
                                            @foreach (var version in group.Versions)
                                            {
                                                <button type="button"
                                                        class="source-version @(version.Id == ResolveRelatedEntry(group).Id ? "active" : "")"
                                                        @onclick="() => SelectRelatedVersion(group, version)">
                                                    @version.Source
                                                </button>
                                            }
                                        </div>
                                    }
                                    @EntryParagraphs(ResolveRelatedEntry(group))
                                </section>
                            }
                        }
                    </section>
                }
            </aside>
        </section>

        <section class="home-recent-grid library-activity-grid">
            <section class="home-panel">
                <header class="settings-panel-header">
                    <div>
                        <p class="eyebrow">Bookmarks</p>
                        <h2>@selectedCategory</h2>
                    </div>
                </header>
                @ActivityList(CategoryBookmarks, true)
            </section>
            <section class="home-panel">
                <header class="settings-panel-header">
                    <div>
                        <p class="eyebrow">Recently Viewed</p>
                        <h2>@selectedCategory</h2>
                    </div>
                    @if (CategoryRecentEntries.Count > 0)
                    {
                        <button type="button" class="text-button no-margin" @onclick="ClearCategoryRecentEntries">Clear</button>
                    }
                </header>
                @ActivityList(CategoryRecentEntries, false)
            </section>
        </section>
    }
</section>

@code {
    [Parameter] public int? EntryId { get; set; }

    private List<WikiEntry> entries = [];
    private WikiEntryGroup? selectedGroup;
    private WikiEntry? selectedEntry;
    private bool isLoading = true;
    private string loadError = "";
    private string searchText = "";
    private string selectedCategory = "";
    private int? appliedEntryId;
    private HashSet<string> activeRelatedLabels = new(StringComparer.OrdinalIgnoreCase);
    private Dictionary<string, int> selectedRelatedEntryIds = new(StringComparer.OrdinalIgnoreCase);

    private string VisibleCountText => string.IsNullOrWhiteSpace(selectedCategory)
        ? $"{CategoryTiles.Count} categories"
        : $"{FilteredGroups.Count} entries";

    private IReadOnlyList<CategoryTile> CategoryTiles => entries
        .Select(entry => entry.Category)
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(value => value)
        .Select(category => new CategoryTile(category, CountPrimaryEntries(category), DescribeCategory(category)))
        .ToList();

    private IReadOnlyList<WikiEntryGroup> FilteredGroups => GroupEntries(entries.Where(MatchesFilter).Where(IsPrimaryListEntry)).ToList();

    private IReadOnlyList<RelatedEntryGroup> RelatedGroups => selectedEntry is null
        ? []
        : entries
            .Where(entry => IsRelatedEntryFor(selectedEntry, entry))
            .GroupBy(BuildRelatedLabel, StringComparer.OrdinalIgnoreCase)
            .Select(group => new RelatedEntryGroup(
                group.Key,
                group.OrderBy(entry => entry.Source).ThenBy(entry => entry.Name).ToList()))
            .OrderBy(group => group.Label)
            .ToList();

    private IReadOnlyList<RelatedEntryGroup> ActiveRelatedGroups => RelatedGroups
        .Where(group => activeRelatedLabels.Contains(group.Label))
        .ToList();

    private IReadOnlyList<WikiEntry> ActiveRelatedEntries => ActiveRelatedGroups
        .Select(ResolveRelatedEntry)
        .ToList();

    private bool IsSelectedEntryBookmarked => selectedEntry is not null && RecentActivity.IsBookmarked(BuildActivityType(selectedEntry.Category), selectedEntry.Id);

    private IReadOnlyList<RecentActivityEntry> CategoryBookmarks => string.IsNullOrWhiteSpace(selectedCategory)
        ? []
        : RecentActivity.GetBookmarks(BuildActivityType(selectedCategory), 8);

    private IReadOnlyList<RecentActivityEntry> CategoryRecentEntries => string.IsNullOrWhiteSpace(selectedCategory)
        ? []
        : RecentActivity.GetRecentEntries(BuildActivityType(selectedCategory), 8);

    private string RelatedTitle => selectedEntry?.Category switch
    {
        "Classes" => "Subclasses",
        "Races" => "Race Versions",
        _ => "Related"
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            entries = (await Database.GetWikiEntriesAsync()).ToList();
            SelectInitialEntry();
        }
        catch (Exception ex)
        {
            loadError = ex.ToString();
        }
        finally
        {
            isLoading = false;
        }
    }

    protected override void OnParametersSet()
    {
        if (!isLoading && EntryId != appliedEntryId)
        {
            SelectInitialEntry();
        }
    }

    private void ShowCategories()
    {
        selectedCategory = "";
        selectedGroup = null;
        selectedEntry = null;
        activeRelatedLabels.Clear();
        selectedRelatedEntryIds.Clear();
        Navigation.NavigateTo("library");
    }

    private void OpenCategory(string category)
    {
        selectedCategory = category;
        searchText = "";
        selectedGroup = FilteredGroups.FirstOrDefault();
        selectedEntry = selectedGroup?.Primary;
        activeRelatedLabels.Clear();
        selectedRelatedEntryIds.Clear();
        TrackSelectedEntry();
    }

    private bool MatchesFilter(WikiEntry entry)
    {
        if (!string.Equals(entry.Category, selectedCategory, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (string.IsNullOrWhiteSpace(searchText))
        {
            return true;
        }

        return entry.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase)
            || entry.Type.Contains(searchText, StringComparison.OrdinalIgnoreCase)
            || entry.Source.Contains(searchText, StringComparison.OrdinalIgnoreCase)
            || entry.Summary.Contains(searchText, StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsPrimaryListEntry(WikiEntry entry)
    {
        return entry.Type is not "Subclass" and not "Race Version";
    }

    private int CountPrimaryEntries(string category)
    {
        return entries.Count(entry => string.Equals(entry.Category, category, StringComparison.OrdinalIgnoreCase)
            && IsPrimaryListEntry(entry));
    }

    private static IEnumerable<WikiEntryGroup> GroupEntries(IEnumerable<WikiEntry> source)
    {
        return source
            .GroupBy(entry => $"{entry.Category}|{entry.Name}", StringComparer.OrdinalIgnoreCase)
            .Select(group => new WikiEntryGroup(group))
            .OrderBy(group => group.Name);
    }

    private void OpenEntry(WikiEntryGroup group)
    {
        selectedGroup = group;
        selectedEntry = group.ResolveVersion(selectedEntry);
        activeRelatedLabels.RemoveWhere(label => RelatedGroups.All(group => !string.Equals(group.Label, label, StringComparison.OrdinalIgnoreCase)));
        selectedRelatedEntryIds = selectedRelatedEntryIds
            .Where(pair => RelatedGroups.Any(group => string.Equals(group.Label, pair.Key, StringComparison.OrdinalIgnoreCase)
                && group.Versions.Any(entry => entry.Id == pair.Value)))
            .ToDictionary(pair => pair.Key, pair => pair.Value, StringComparer.OrdinalIgnoreCase);
        TrackSelectedEntry();
        Navigation.NavigateTo($"library/{selectedEntry.Id}", replace: true);
    }

    private void SelectVersion(WikiEntry entry)
    {
        selectedEntry = entry;
        activeRelatedLabels.Clear();
        selectedRelatedEntryIds.Clear();
        TrackSelectedEntry();
        Navigation.NavigateTo($"library/{entry.Id}", replace: true);
    }

    private void ToggleRelatedGroup(RelatedEntryGroup group)
    {
        if (!activeRelatedLabels.Add(group.Label))
        {
            activeRelatedLabels.Remove(group.Label);
            selectedRelatedEntryIds.Remove(group.Label);
            return;
        }

        selectedRelatedEntryIds[group.Label] = group.Primary.Id;
    }

    private void SelectRelatedVersion(RelatedEntryGroup group, WikiEntry entry)
    {
        selectedRelatedEntryIds[group.Label] = entry.Id;
    }

    private WikiEntry ResolveRelatedEntry(RelatedEntryGroup group)
    {
        return selectedRelatedEntryIds.TryGetValue(group.Label, out var entryId)
            ? group.Versions.FirstOrDefault(entry => entry.Id == entryId) ?? group.Primary
            : group.Primary;
    }

    private void SelectInitialEntry()
    {
        if (EntryId is null)
        {
            return;
        }

        var entry = entries.FirstOrDefault(entry => entry.Id == EntryId.Value);
        if (entry is null)
        {
            return;
        }

        appliedEntryId = EntryId;
        selectedCategory = entry.Category;
        selectedGroup = GroupEntries(entries.Where(candidate => string.Equals(candidate.Category, entry.Category, StringComparison.OrdinalIgnoreCase)
            && IsPrimaryListEntry(candidate))).FirstOrDefault(group => group.Versions.Any(version => version.Id == entry.Id));
        selectedEntry = entry;
        TrackSelectedEntry();
    }

    private void TrackSelectedEntry()
    {
        if (selectedEntry is null)
        {
            return;
        }

        RecentActivity.Track(
            BuildActivityType(selectedEntry.Category),
            selectedEntry.Id,
            selectedEntry.Name,
            $"{selectedEntry.Type} - {selectedEntry.Source}",
            $"library/{selectedEntry.Id}");
    }

    private void ToggleSelectedBookmark()
    {
        if (selectedEntry is null)
        {
            return;
        }

        RecentActivity.ToggleBookmark(
            BuildActivityType(selectedEntry.Category),
            selectedEntry.Id,
            selectedEntry.Name,
            $"{selectedEntry.Type} - {selectedEntry.Source}",
            $"library/{selectedEntry.Id}");
    }

    private void ToggleActivityBookmark(RecentActivityEntry entry)
    {
        RecentActivity.ToggleBookmark(entry.EntryType, entry.EntityId, entry.Title, entry.Subtitle, entry.Route);
    }

    private void OpenActivityEntry(RecentActivityEntry entry)
    {
        Navigation.NavigateTo(entry.Route);
    }

    private void ClearCategoryRecentEntries()
    {
        RecentActivity.ClearRecentEntries(BuildActivityType(selectedCategory));
    }

    private static string BuildActivityType(string category)
    {
        return $"Wiki:{category}";
    }

    private static bool IsRelatedEntryFor(WikiEntry parent, WikiEntry candidate)
    {
        if (parent.Type == "Class" && candidate.Type == "Subclass")
        {
            return candidate.Name.StartsWith($"{parent.Name}:", StringComparison.OrdinalIgnoreCase);
        }

        if (parent.Type == "Race" && candidate.Type == "Race Version")
        {
            return candidate.Name.StartsWith($"{parent.Name}:", StringComparison.OrdinalIgnoreCase);
        }

        return false;
    }

    private static bool IsClassEntry(WikiEntry entry)
    {
        return entry.Type is "Class" or "Subclass";
    }

    private static string BuildRelatedLabel(WikiEntry entry)
    {
        var separatorIndex = entry.Name.IndexOf(':', StringComparison.Ordinal);
        return separatorIndex >= 0 && separatorIndex + 1 < entry.Name.Length
            ? entry.Name[(separatorIndex + 1)..].Trim()
            : entry.Name;
    }

    private static string DescribeCategory(string category)
    {
        return category switch
        {
            "Classes" => "Class features and subclass references",
            "Feats" => "Feat descriptions and prerequisites",
            "Races" => "Races and race version details",
            "Conditions" => "Conditions and diseases",
            "Rules" => "Actions and variant rules",
            _ => "Compendium entries"
        };
    }

    private static IReadOnlyList<FeatureLevel> BuildFeatureLevels(WikiEntry entry)
    {
        return BuildFeatureLevels(entry, "classFeatures");
    }

    private static IReadOnlyList<FeatureLevel> BuildMergedClassFeatureLevels(WikiEntry classEntry, IReadOnlyList<WikiEntry> subclassEntries)
    {
        var classFeatures = BuildFeatureLevels(classEntry, "classFeatures");
        var subclassFeatures = subclassEntries.SelectMany(subclass => BuildMappedSubclassFeatureLevels(classEntry.RawJson, subclass)).ToList();

        return classFeatures.Concat(subclassFeatures)
            .GroupBy(level => level.Level)
            .OrderBy(group => group.Key)
            .Select(group => new FeatureLevel(
                group.Key,
                group.SelectMany(level => level.Features)
                    .GroupBy(feature => feature.Key, StringComparer.OrdinalIgnoreCase)
                    .Select(group => group.First())
                    .OrderBy(feature => feature.Name)
                    .ToList()))
            .ToList();
    }

    private static IReadOnlyList<FeatureLevel> BuildMappedSubclassFeatureLevels(string classRawJson, WikiEntry subclassEntry)
    {
        var subclassLevels = BuildFeatureLevels(subclassEntry, "subclassFeatures", BuildRelatedLabel(subclassEntry));
        var classSubclassLevels = BuildSubclassGrantLevels(classRawJson).ToList();
        if (subclassLevels.Count == 0 || classSubclassLevels.Count == 0)
        {
            return subclassLevels;
        }

        return subclassLevels
            .Select((level, index) => new FeatureLevel(
                index < classSubclassLevels.Count ? classSubclassLevels[index] : level.Level,
                level.Features))
            .GroupBy(level => level.Level)
            .OrderBy(group => group.Key)
            .Select(group => new FeatureLevel(
                group.Key,
                group.SelectMany(level => level.Features)
                    .GroupBy(feature => feature.Key, StringComparer.OrdinalIgnoreCase)
                    .Select(group => group.First())
                    .OrderBy(feature => feature.Name)
                    .ToList()))
            .ToList();
    }

    private static IEnumerable<int> BuildSubclassGrantLevels(string classRawJson)
    {
        if (string.IsNullOrWhiteSpace(classRawJson))
        {
            yield break;
        }

        using var document = JsonDocument.Parse(classRawJson);
        if (!document.RootElement.TryGetProperty("classFeatures", out var features) || features.ValueKind != JsonValueKind.Array)
        {
            yield break;
        }

        foreach (var feature in features.EnumerateArray())
        {
            if (feature.ValueKind != JsonValueKind.Object
                || !feature.TryGetProperty("gainSubclassFeature", out var gainSubclassFeature)
                || gainSubclassFeature.ValueKind != JsonValueKind.True
                || !feature.TryGetProperty("classFeature", out var classFeature))
            {
                continue;
            }

            var level = ParseFeatureReferenceLevel(classFeature.GetString());
            if (level is >= 1 and <= 20)
            {
                yield return level;
            }
        }
    }

    private static int ParseFeatureReferenceLevel(string? reference)
    {
        if (string.IsNullOrWhiteSpace(reference))
        {
            return 0;
        }

        return reference
            .Split('|', StringSplitOptions.None)
            .Select(part => int.TryParse(part, out var parsed) ? parsed : 0)
            .LastOrDefault(parsed => parsed is >= 1 and <= 20);
    }

    private static IReadOnlyList<FeatureLevel> BuildFeatureLevels(WikiEntry entry, string propertyName, string sourceLabel = "")
    {
        if (string.IsNullOrWhiteSpace(entry.RawJson))
        {
            return [];
        }

        using var document = JsonDocument.Parse(entry.RawJson);
        if (!document.RootElement.TryGetProperty(propertyName, out var features)
            || features.ValueKind != JsonValueKind.Array)
        {
            return [];
        }

        var details = BuildFeatureDetailLookup(document.RootElement, sourceLabel);
        return features
            .EnumerateArray()
            .Select(feature => ParseFeatureReference(feature, details, sourceLabel))
            .Where(feature => feature is not null)
            .Select(feature => feature!)
            .GroupBy(feature => feature.Level)
            .OrderBy(group => group.Key)
            .Select(group => new FeatureLevel(
                group.Key,
                group
                    .GroupBy(feature => feature.Key, StringComparer.OrdinalIgnoreCase)
                    .Select(group => group.First())
                    .OrderBy(feature => feature.Name)
                    .ToList()))
            .ToList();
    }

    private static Dictionary<string, FeatureEntry> BuildFeatureDetailLookup(JsonElement root, string sourceLabel)
    {
        var details = new Dictionary<string, FeatureEntry>(StringComparer.OrdinalIgnoreCase);
        if (!root.TryGetProperty("_featureDetails", out var featureDetails)
            || featureDetails.ValueKind != JsonValueKind.Array)
        {
            return details;
        }

        foreach (var featureDetail in featureDetails.EnumerateArray())
        {
            var feature = ParseFeatureDetail(featureDetail, sourceLabel);
            if (feature is not null)
            {
                details[feature.Key] = feature;
            }
        }

        return details;
    }

    private static FeatureEntry? ParseFeatureReference(JsonElement element, IReadOnlyDictionary<string, FeatureEntry> details, string sourceLabel)
    {
        var reference = element.ValueKind switch
        {
            JsonValueKind.String => element.GetString(),
            JsonValueKind.Object when element.TryGetProperty("classFeature", out var classFeature) => classFeature.GetString(),
            JsonValueKind.Object when element.TryGetProperty("subclassFeature", out var subclassFeature) => subclassFeature.GetString(),
            _ => null
        };

        if (string.IsNullOrWhiteSpace(reference))
        {
            return null;
        }

        var parts = reference.Split('|', StringSplitOptions.None);
        var level = ParseFeatureReferenceLevel(reference);
        if (level == 0)
        {
            return null;
        }

        var name = CleanMarkup(parts[0]);
        var key = BuildFeatureKey(name, level, sourceLabel);
        return details.TryGetValue(key, out var detail)
            ? detail
            : new FeatureEntry(name, level, key, sourceLabel, []);
    }

    private static FeatureEntry? ParseFeatureDetail(JsonElement element, string sourceLabel)
    {
        var name = ReadJsonString(element, "name");
        if (string.IsNullOrWhiteSpace(name))
        {
            return null;
        }

        var level = element.TryGetProperty("level", out var levelElement)
            && levelElement.ValueKind == JsonValueKind.Number
            && levelElement.TryGetInt32(out var parsedLevel)
            ? parsedLevel
            : 0;

        var paragraphs = element.TryGetProperty("entries", out var entries)
            ? ExtractParagraphs(entries).ToList()
            : [];

        return new FeatureEntry(name, level, BuildFeatureKey(name, level, sourceLabel), sourceLabel, paragraphs);
    }

    private static string BuildFeatureKey(string name, int level, string sourceLabel)
    {
        return $"{CleanMarkup(name).Trim()}|{level}|{sourceLabel}";
    }

    private static string CleanMarkup(string value)
    {
        return value
            .Replace("{@i ", "", StringComparison.OrdinalIgnoreCase)
            .Replace("{@b ", "", StringComparison.OrdinalIgnoreCase)
            .Replace("}", "", StringComparison.OrdinalIgnoreCase);
    }

    private static IEnumerable<string> ExtractParagraphs(JsonElement element)
    {
        if (element.ValueKind == JsonValueKind.String)
        {
            yield return element.GetString() ?? "";
            yield break;
        }

        if (element.ValueKind == JsonValueKind.Object)
        {
            if (element.TryGetProperty("entry", out var entry))
            {
                foreach (var value in ExtractParagraphs(entry))
                {
                    yield return value;
                }
            }

            if (element.TryGetProperty("entries", out var entries))
            {
                foreach (var value in ExtractParagraphs(entries))
                {
                    yield return value;
                }
            }

            if (element.TryGetProperty("items", out var items))
            {
                foreach (var value in ExtractParagraphs(items))
                {
                    yield return value;
                }
            }

            yield break;
        }

        if (element.ValueKind != JsonValueKind.Array)
        {
            yield break;
        }

        foreach (var item in element.EnumerateArray())
        {
            if (item.ValueKind == JsonValueKind.Object && item.TryGetProperty("name", out var name))
            {
                var text = string.Join(" ", ExtractParagraphs(item));
                if (!string.IsNullOrWhiteSpace(text))
                {
                    yield return $"{name.GetString()}: {text}";
                }
                continue;
            }

            foreach (var value in ExtractParagraphs(item))
            {
                yield return value;
            }
        }
    }

    private static string ReadJsonString(JsonElement element, string propertyName)
    {
        return element.ValueKind == JsonValueKind.Object
            && element.TryGetProperty(propertyName, out var property)
            && property.ValueKind == JsonValueKind.String
            ? property.GetString() ?? ""
            : "";
    }

    private sealed record CategoryTile(string Category, int Count, string Description);
    private sealed record RelatedEntryGroup(string Label, IReadOnlyList<WikiEntry> Versions)
    {
        public WikiEntry Primary => Versions.First();
    }

    private sealed record FeatureLevel(int Level, IReadOnlyList<FeatureEntry> Features);
    private sealed record FeatureEntry(string Name, int Level, string Key, string SourceLabel, IReadOnlyList<string> Paragraphs);
}

@code {
    private RenderFragment EntryParagraphs(WikiEntry entry) => @<section class="detail-section">
        @if (entry.Paragraphs.Count == 0)
        {
            <p class="muted">No detail text found.</p>
        }
        else
        {
            @foreach (var paragraph in entry.Paragraphs)
            {
                <p><MarkupText Text="@paragraph" /></p>
            }
        }
    </section>;

    private RenderFragment ActivityList(IReadOnlyList<RecentActivityEntry> activityEntries, bool bookmarks) => @<section class="home-recent-list">
        @if (activityEntries.Count == 0)
        {
            <section class="home-empty-state">
                <p class="eyebrow">Empty</p>
                <h3>@(bookmarks ? "No bookmarks yet." : "No entries viewed yet.")</h3>
            </section>
        }
        else
        {
            @foreach (var entry in activityEntries)
            {
                <article class="home-recent-row">
                    <button type="button" class="home-recent-content" @onclick="() => OpenActivityEntry(entry)">
                        <span class="source-code">@entry.EntryType.Replace("Wiki:", "", StringComparison.OrdinalIgnoreCase)</span>
                        <strong>@entry.Title</strong>
                        <small>@entry.Subtitle</small>
                    </button>
                    <button type="button"
                            class="icon-button bookmark-button @(RecentActivity.IsBookmarked(entry.EntryType, entry.EntityId) ? "active" : "")"
                            title="Toggle bookmark"
                            @onclick="() => ToggleActivityBookmark(entry)">
                        @(RecentActivity.IsBookmarked(entry.EntryType, entry.EntityId) ? "★" : "☆")
                    </button>
                </article>
            }
        }
    </section>;

    private RenderFragment ClassFeatureSections(WikiEntry entry, IReadOnlyList<WikiEntry> activeRelatedEntries) => @<section class="detail-section class-feature-section">
        <h2>Class Features</h2>
        @{
            var levels = BuildMergedClassFeatureLevels(entry, activeRelatedEntries);
        }
        @if (levels.Count == 0)
        {
            @EntryParagraphs(entry)
        }
        else
        {
            <div class="feature-level-list">
                @foreach (var level in levels)
                {
                    <article class="feature-level-row">
                        <span class="feature-level-badge">Lvl @level.Level</span>
                        <div>
                            @foreach (var feature in level.Features)
                            {
                                <details class="feature-detail-toggle">
                                    <summary class="feature-pill">
                                        @if (!string.IsNullOrWhiteSpace(feature.SourceLabel))
                                        {
                                            <span class="source-badge">@feature.SourceLabel</span>
                                        }
                                        @feature.Name
                                    </summary>
                                    <div class="feature-detail-body">
                                        @foreach (var paragraph in feature.Paragraphs)
                                        {
                                            <p><MarkupText Text="@paragraph" /></p>
                                        }
                                    </div>
                                </details>
                            }
                        </div>
                    </article>
                }
            </div>
        }
    </section>;
}
