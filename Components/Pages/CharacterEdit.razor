            "Race",
            race.Name,
            race.Source,
            race.Page,
            [
                new OptionDetailStat("Size", FormatJsonSummary(race.SizeJson)),
                new OptionDetailStat("Speed", FormatJsonSummary(race.SpeedJson)),
                new OptionDetailStat("Ability", FormatJsonSummary(race.AbilityJson))
            ],
            [],
            [],
            []);
    }

    private static OptionDetail BuildBackgroundDetail(BackgroundDefinition background)
    {
        return new OptionDetail(
            "Background",
            background.Name,
            background.Source,
            background.Page,
            [
                new OptionDetailStat("Ability", FormatJsonSummary(background.AbilityJson)),
                new OptionDetailStat("Skills", FormatJsonSummary(background.SkillProficienciesJson)),
