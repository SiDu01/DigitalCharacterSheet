    private static OptionDetail BuildFeatDetail(FeatDefinition feat)
    {
        return new OptionDetail(
            "Feat",
            feat.Name,
            feat.Source,
            feat.Page,
            [
                new OptionDetailStat("Category", string.IsNullOrWhiteSpace(feat.Category) ? "None" : feat.Category),
                new OptionDetailStat("Prerequisite", FormatJsonSummary(feat.PrerequisiteJson)),
