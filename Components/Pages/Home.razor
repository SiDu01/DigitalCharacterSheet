@page "/"
@inject AppDatabase Database
@inject NavigationManager Navigation
@inject RecentActivityService RecentActivity

<PageTitle>Home</PageTitle>

<section class="home-shell">
    <header class="page-header home-header">
        <div>
            <p class="eyebrow">Digital Character Sheet</p>
            <h1>Dashboard</h1>
        </div>
    </header>

    <section class="home-tile-grid" aria-label="Main areas">
        @foreach (var tile in DashboardTiles)
        {
            <button type="button" class="home-tile" @onclick="() => OpenRoute(tile.Route)">
                <span>@tile.CountText</span>
                <strong>@tile.Title</strong>
                <small>@tile.Subtitle</small>
            </button>
        }
    </section>

    <section class="home-recent-grid">
        <section class="home-panel">
            <header class="settings-panel-header">
                <div>
                    <p class="eyebrow">Bookmarks</p>
                    <h2>Saved Entries</h2>
                </div>
            </header>
            <section class="home-panel-tools" aria-label="Bookmark filters">
                @foreach (var type in EntryTypeFilters)
                {
                    <button type="button"
                            class="source-version @(selectedBookmarkType == type ? "active" : "")"
                            @onclick="() => SetBookmarkFilter(type)">
                        @(string.IsNullOrWhiteSpace(type) ? "All" : type)
                    </button>
                }
            </section>

            @if (isLoading)
            {
                <section class="home-empty-state">
                    <p class="eyebrow">Loading</p>
                    <h3>Loading dashboard...</h3>
                </section>
            }
            else if (bookmarks.Count == 0)
            {
                <section class="home-empty-state">
                    <p class="eyebrow">Empty</p>
                    <h3>No bookmarks yet.</h3>
                    <p class="muted">Mark characters, spells, or items with the star to find them here again.</p>
                </section>
            }
            else
            {
                <section class="home-recent-list">
                    @foreach (var entry in bookmarks)
                    {
                        <article class="home-recent-row">
                            <button type="button" class="home-recent-content" @onclick="() => OpenEntry(entry)">
                                <span class="source-code">@entry.EntryType</span>
                                <strong>@entry.Title</strong>
                                <small>@entry.Subtitle</small>
                            </button>
                            <button type="button" class="icon-button bookmark-button active" title="Remove bookmark" @onclick="() => ToggleBookmark(entry)">★</button>
                        </article>
                    }
                </section>
            }
        </section>

        <section class="home-panel">
            <header class="settings-panel-header">
                <div>
                    <p class="eyebrow">Recently Viewed</p>
                    <h2>Entries</h2>
                </div>
                @if (recentEntries.Count > 0)
                {
                    <button type="button" class="text-button no-margin" @onclick="ClearRecentEntries">Clear</button>
                }
            </header>
            <section class="home-panel-tools" aria-label="Recent filters">
                @foreach (var type in RecentTypeFilters)
                {
                    <button type="button"
                            class="source-version @(selectedRecentType == type ? "active" : "")"
                            @onclick="() => SetRecentFilter(type)">
                        @(string.IsNullOrWhiteSpace(type) ? "All" : type)
                    </button>
                }
            </section>

            @if (isLoading)
            {
                <section class="home-empty-state">
                    <p class="eyebrow">Loading</p>
                    <h3>Loading dashboard...</h3>
                </section>
            }
            else if (recentEntries.Count == 0)
            {
                <section class="home-empty-state">
                    <p class="eyebrow">Empty</p>
                    <h3>No entries viewed yet.</h3>
                    <p class="muted">Opened spells and items appear in this list automatically.</p>
                </section>
            }
            else
            {
                <section class="home-recent-list">
                    @foreach (var entry in recentEntries)
                    {
                        <article class="home-recent-row">
                            <button type="button" class="home-recent-content" @onclick="() => OpenEntry(entry)">
                                <span class="source-code">@entry.EntryType</span>
                                <strong>@entry.Title</strong>
                                <small>@entry.Subtitle</small>
                            </button>
                            <button type="button"
                                    class="icon-button bookmark-button @(RecentActivity.IsBookmarked(entry.EntryType, entry.EntityId) ? "active" : "")"
                                    title="Toggle bookmark"
                                    @onclick="() => ToggleBookmark(entry)">
                                @(RecentActivity.IsBookmarked(entry.EntryType, entry.EntityId) ? "★" : "☆")
                            </button>
                        </article>
                    }
                </section>
            }
        </section>
    </section>
</section>

@code {
    private bool isLoading = true;
    private int characterCount;
    private int spellCount;
    private int itemCount;
    private int wikiCount;
    private List<RecentActivityEntry> bookmarks = [];
    private List<RecentActivityEntry> recentEntries = [];
    private string selectedBookmarkType = "";
    private string selectedRecentType = "";
    private static readonly string[] EntryTypeFilters = ["", "Character", "Spell", "Item"];
    private static readonly string[] RecentTypeFilters = ["", "Spell", "Item"];

    private IReadOnlyList<HomeTile> DashboardTiles =>
    [
        new("Characters", "Manage, create, and play characters", characterCount.ToString(), "characters"),
        new("Spells", "Spellbook, filters, and detail view", spellCount.ToString(), "spells"),
        new("Items", "Equipment, magic items, and inventory", itemCount.ToString(), "items"),
        new("Library", "Conditions, actions, and rules", wikiCount.ToString(), "library"),
        new("Settings", "Theme, sources, import, and export", "", "settings")
    ];

    protected override async Task OnInitializedAsync()
    {
        var characters = await Database.GetCharactersAsync();
        characterCount = characters.Count;
        spellCount = (await Database.GetSpellSummariesAsync()).Count;
        itemCount = (await Database.GetItemDefinitionsAsync()).Count;
        wikiCount = (await Database.GetWikiEntriesAsync()).Count;
        RefreshActivityLists();
        isLoading = false;
    }

    private void OpenRoute(string route)
    {
        if (!string.IsNullOrWhiteSpace(route))
        {
            Navigation.NavigateTo(route);
        }
    }

    private void OpenEntry(RecentActivityEntry entry)
    {
        OpenRoute(BuildEntryRoute(entry));
    }

    private static string BuildEntryRoute(RecentActivityEntry entry)
    {
        return string.Equals(entry.EntryType, "Item", StringComparison.OrdinalIgnoreCase)
            && entry.EntityId > 0
            && (string.IsNullOrWhiteSpace(entry.Route) || string.Equals(entry.Route, "items", StringComparison.OrdinalIgnoreCase))
                ? $"items/{entry.EntityId}"
                : entry.Route;
    }

    private void ToggleBookmark(RecentActivityEntry entry)
    {
        RecentActivity.ToggleBookmark(entry.EntryType, entry.EntityId, entry.Title, entry.Subtitle, BuildEntryRoute(entry));
        RefreshActivityLists();
    }

    private void SetBookmarkFilter(string entryType)
    {
        selectedBookmarkType = entryType;
        RefreshActivityLists();
    }

    private void SetRecentFilter(string entryType)
    {
        selectedRecentType = entryType;
        RefreshActivityLists();
    }

    private void ClearRecentEntries()
    {
        RecentActivity.ClearRecentEntries(string.IsNullOrWhiteSpace(selectedRecentType) ? null : selectedRecentType);
        RefreshActivityLists();
    }

    private void RefreshActivityLists()
    {
        bookmarks = RecentActivity.GetBookmarks(string.IsNullOrWhiteSpace(selectedBookmarkType) ? null : selectedBookmarkType, 24).ToList();
        recentEntries = RecentActivity.GetRecentEntries(string.IsNullOrWhiteSpace(selectedRecentType) ? null : selectedRecentType, 16)
            .Where(entry => !string.Equals(entry.EntryType, "Character", StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private sealed record HomeTile(string Title, string Subtitle, string CountText, string Route);
}
