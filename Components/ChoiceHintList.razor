@if (Hints.Count > 0)
{
    <div class="choice-hint-list">
        @foreach (var hint in Hints)
        {
            <div class="choice-hint">
                <span>@hint.Source</span>
                <p><MarkupText Text="@hint.Description" /></p>
            </div>
        }
    </div>
}

@code {
    [Parameter] public IReadOnlyList<CharacterOptionChoice> Hints { get; set; } = [];
}
